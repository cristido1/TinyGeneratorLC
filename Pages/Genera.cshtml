@page
@model GeneraModel
@{
    ViewData["Title"] = "Genera una storia lunga";
    ViewData["PageDescription"] = "Crea una storia completa con trama, personaggi e capitoli";
}

<style>
    .generator-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        align-items: start;
        margin-bottom: 18px;
    }

    .generator-panel.note-card {
        margin-bottom: 0 !important;
        max-width: none !important;
        width: 100%;
        border: 1px solid #dbe4ea;
        border-radius: 14px;
        background:
            radial-gradient(circle at 85% 12%, rgba(44, 111, 187, 0.10), transparent 42%),
            linear-gradient(180deg, #ffffff, #f8fbff);
        overflow: hidden;
        box-shadow: 0 4px 14px rgba(18, 42, 66, 0.06);
    }

    /* Disable global note-card animated green orbit border on this page */
    .generator-panel.note-card::before,
    .generator-panel.note-card:hover::before {
        content: none !important;
        display: none !important;
        animation: none !important;
        opacity: 0 !important;
        background: none !important;
    }

    .generator-panel.note-card:hover {
        transform: none !important;
    }

    .generator-panel[open] {
        grid-column: 1 / -1;
        box-shadow: 0 12px 28px rgba(18, 42, 66, 0.12);
    }

    .generator-panel:focus-within {
        background:
            linear-gradient(180deg, #f4fbf6, #edf8f0) !important;
        border-color: #cfe6d5 !important;
        box-shadow: 0 6px 18px rgba(77, 135, 95, 0.10) !important;
        animation: none !important;
    }

    .generator-panel:focus-within > summary.generator-summary {
        background: linear-gradient(180deg, rgba(240, 251, 244, 0.95), rgba(247, 253, 249, 0.95)) !important;
        animation: none !important;
    }

    .generator-panel summary:focus,
    .generator-panel summary:focus-visible {
        outline: none;
    }

    .generator-panel > summary.generator-summary {
        list-style: none;
        cursor: pointer;
        margin: 0 !important;
        padding: 12px 14px 12px 84px;
        min-height: 76px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        border-bottom: 1px solid transparent;
        user-select: none;
    }

    .generator-panel > summary.generator-summary::-webkit-details-marker {
        display: none;
    }

    .generator-panel[open] > summary.generator-summary {
        border-bottom-color: #e5edf4;
        background: linear-gradient(180deg, rgba(244, 249, 255, 0.95), rgba(255,255,255,0.95));
    }

    .generator-panel > summary.generator-summary::before {
        content: attr(data-icon);
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-52%);
        width: 62px;
        height: 62px;
        display: grid;
        place-items: center;
        font-size: 2.15rem;
        color: rgba(0, 0, 0, 0.22);
        background: transparent;
        border: none;
        box-shadow: none;
        filter: grayscale(1) saturate(0);
        pointer-events: none;
        z-index: 0;
    }

    .generator-panel > summary.generator-summary::after {
        content: attr(data-subtitle);
        margin-top: 2px;
        font-size: 0.78rem;
        color: #557087;
        font-weight: 500;
    }

    .generator-panel > summary.generator-summary .generator-summary-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #102335;
        line-height: 1.2;
        padding-right: 24px;
        position: relative;
        z-index: 1;
    }

    .generator-panel > summary.generator-summary .generator-summary-chevron {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #5d7387;
        font-size: 1rem;
        transition: transform .15s ease;
        z-index: 1;
    }

    .generator-panel[open] > summary.generator-summary .generator-summary-chevron {
        transform: translateY(-50%) rotate(180deg);
    }

    .generator-panel .generator-panel-body {
        padding: 14px;
    }

    @@media (max-width: 1100px) {
        .generator-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .generator-panel[open] {
            grid-column: 1 / -1;
        }
    }

    @@media (max-width: 760px) {
        .generator-grid {
            grid-template-columns: 1fr;
        }
        .generator-panel[open] {
            grid-column: auto;
        }
        .generator-panel > summary.generator-summary {
            min-height: 70px;
            padding-left: 78px;
        }
        .generator-panel > summary.generator-summary::before {
            width: 52px;
            height: 52px;
            font-size: 1.8rem;
        }
    }
</style>

<div class="generator-grid" id="generationPanels">
<details class="note-card generator-panel">
    <summary class="note-title generator-summary" data-icon="◎" data-subtitle="Nuovo runtime in-memory (skeleton UI)">
        <span class="generator-summary-title">Narrative Runtime Engine (NRE)</span>
        <span class="generator-summary-chevron">▾</span>
    </summary>
    <div class="generator-panel-body">
    <form id="nreForm">
        @Html.AntiForgeryToken()
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:260px; flex:1;">
                <label for="NreTitle" class="note-title">Titolo (opzionale)</label>
                <input id="NreTitle" name="NreTitle" class="keep-input font-monospace" style="width:100%; padding:8px" maxlength="160" placeholder="Titolo working" value="@Model.NreTitle" />
            </div>
            <div style="min-width:220px; flex:0 0 220px;">
                <label for="NreMethod" class="note-title">Method</label>
                <select id="NreMethod" name="NreMethod" class="keep-input" style="width:100%; padding:8px">
                    <option value="state_driven" selected="@(string.Equals(Model.NreMethod, "state_driven", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">state_driven</option>
                    <option value="single_pass" selected="@(string.Equals(Model.NreMethod, "single_pass", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">single_pass</option>
                </select>
            </div>
            <div style="min-width:220px; flex:0 0 220px;">
                <label for="NreStructureMode" class="note-title">Struttura narrativa</label>
                <select id="NreStructureMode" name="NreStructureMode" class="keep-input" style="width:100%; padding:8px">
                    <option value="standard" selected="@(string.Equals(Model.NreStructureMode, "standard", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Standard</option>
                    <option value="military_strict" selected="@(string.Equals(Model.NreStructureMode, "military_strict", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Militare rigorosa</option>
                </select>
            </div>
            <div style="min-width:220px; flex:0 0 220px;">
                <label for="NreCostSeverity" class="note-title">Gravità conseguenze</label>
                <select id="NreCostSeverity" name="NreCostSeverity" class="keep-input" style="width:100%; padding:8px">
                    <option value="low" selected="@(string.Equals(Model.NreCostSeverity, "low", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Bassa</option>
                    <option value="medium" selected="@(string.Equals(Model.NreCostSeverity, "medium", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Media</option>
                    <option value="high" selected="@(string.Equals(Model.NreCostSeverity, "high", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Alta</option>
                </select>
            </div>
            <div style="min-width:220px; flex:0 0 220px;">
                <label for="NreCombatIntensity" class="note-title">Intensità combattimento</label>
                <select id="NreCombatIntensity" name="NreCombatIntensity" class="keep-input" style="width:100%; padding:8px">
                    <option value="low" selected="@(string.Equals(Model.NreCombatIntensity, "low", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Bassa</option>
                    <option value="normal" selected="@(string.Equals(Model.NreCombatIntensity, "normal", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Normale</option>
                    <option value="high" selected="@(string.Equals(Model.NreCombatIntensity, "high", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Alta</option>
                    <option value="total_war" selected="@(string.Equals(Model.NreCombatIntensity, "total_war", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Guerra totale</option>
                </select>
            </div>
            <div style="min-width:160px; flex:0 0 160px;">
                <label for="NreMaxSteps" class="note-title">MaxSteps</label>
                <input id="NreMaxSteps" name="NreMaxSteps" class="keep-input" style="width:100%; padding:8px" type="number" min="1" max="200" value="@Model.NreMaxSteps" />
            </div>
        </div>
        <div style="margin-bottom:10px;">
            <label for="NreTheme" class="note-title">Tema</label>
            <textarea id="NreTheme" name="NreTheme" class="keep-input font-monospace" rows="3" style="width:100%; padding:8px" placeholder="ribellione contro una corporazione, missione fallita, protagonista ambigua">@Model.NreTheme</textarea>
        </div>
        <div style="margin-bottom:10px;">
            <label for="NreSetting" class="note-title">Ambientazione</label>
            <textarea id="NreSetting" name="NreSetting" class="keep-input font-monospace" rows="3" style="width:100%; padding:8px" placeholder="megalopoli costiera allagata, colonia orbitale isolata, Italia anni 90 alternativa">@Model.NreSetting</textarea>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:220px; flex:1;">
                <label for="NreGenre" class="note-title">Genere</label>
                <input id="NreGenre" name="NreGenre" class="keep-input" style="width:100%; padding:8px" placeholder="thriller, fantascienza, noir" value="@Model.NreGenre" />
            </div>
            <div style="min-width:220px; flex:1;">
                <label for="NreTone" class="note-title">Tono desiderato</label>
                <input id="NreTone" name="NreTone" class="keep-input" style="width:100%; padding:8px" placeholder="teso, cupo, realistico" value="@Model.NreTone" />
            </div>
        </div>
        <div style="margin-bottom:10px;">
            <label for="NreConstraints" class="note-title">Eventuali vincoli</label>
            <textarea id="NreConstraints" name="NreConstraints" class="keep-input font-monospace" rows="3" style="width:100%; padding:8px" placeholder="niente magia, POV in terza persona, finale aperto, dialoghi brevi">@Model.NreConstraints</textarea>
        </div>
        <div style="margin-bottom:10px;">
            <label for="NreResourceHints" class="note-title">Risorse iniziali (opzionale)</label>
            <textarea id="NreResourceHints" name="NreResourceHints" class="keep-input font-monospace" rows="3" style="width:100%; padding:8px" placeholder="nave Colombo: 10 missili antimateria, capitano Carta, squadra abbordaggio alfa, drone ricognitore OR-7">@Model.NreResourceHints</textarea>
        </div>
        <div id="savedNreStories" style="margin-bottom:10px; display:flex; gap:8px; flex-wrap:wrap"></div>
        <input type="hidden" id="NrePrompt" name="NrePrompt" value="@Model.NrePrompt" />
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:220px; flex:0 0 220px;">
                <label for="NreSeriesId" class="note-title">SeriesId (opzionale)</label>
                <input id="NreSeriesId" name="NreSeriesId" class="keep-input" style="width:100%; padding:8px" type="number" min="1" value="@Model.NreSeriesId" />
            </div>
            <div style="min-width:240px; flex:0 0 240px;">
                <label for="NreSeriesEpisodeNumber" class="note-title">SeriesEpisodeNumber (opzionale)</label>
                <input id="NreSeriesEpisodeNumber" name="NreSeriesEpisodeNumber" class="keep-input" style="width:100%; padding:8px" type="number" min="1" value="@Model.NreSeriesEpisodeNumber" />
            </div>
            <div style="display:flex; align-items:flex-end; min-width:260px; flex:1;">
                <label style="display:flex; align-items:center; gap:8px; margin:0 0 8px 0;">
                    <input type="checkbox" id="NreSnapshotOnFailure" name="NreSnapshotOnFailure" value="true" @(Model.NreSnapshotOnFailure ? "checked" : null) />
                    <span class="note-title" style="margin:0;">Snapshot on failure</span>
                </label>
            </div>
        </div>
        <div id="nreError" role="alert" style="color:#b00020; margin-bottom:8px; display:none"></div>
        <div style="display:flex; gap:8px; align-items:center;">
            <button type="button" id="suggestNrePromptBtn" class="action-btn" style="font-weight:600; padding:8px 14px; display:inline-flex; align-items:center; gap:8px;">
                <span id="suggestNrePromptSpinner" class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display:none;"></span>
                <span id="suggestNrePromptBtnText">Suggerisci titolo+prompt</span>
            </button>
            <button type="button" id="suggestNreMilitaryPromptBtn" class="action-btn" style="font-weight:600; padding:8px 14px">
                Suggerisci militare (flotta italiana)
            </button>
            <button type="button" id="suggestNreReligiousPromptBtn" class="action-btn" style="font-weight:600; padding:8px 14px">
                Suggerisci religioso (Vaticano horror)
            </button>
            <button type="button" id="startNreBtn" class="action-btn primary" style="font-weight:600; padding:8px 14px">Avvia NRE</button>
            <span style="font-size:0.85em; color:#5d7387;">Versione iniziale collegata a planner/writer/evaluator via CallCenter.</span>
        </div>
    </form>
    </div>
</details>

<details class="note-card generator-panel">
    <summary class="note-title generator-summary" data-icon="◫" data-subtitle="Template multi-step + writer selezionato">
        <span class="generator-summary-title">Genera storia multi-step</span>
        <span class="generator-summary-chevron">▾</span>
    </summary>
    <div class="generator-panel-body">
    <form id="genForm">
        @Html.AntiForgeryToken()
        <div style="margin-bottom:10px">
            <label for="Title" class="note-title">Titolo della storia</label>
            <input class="keep-input font-monospace" id="Title" name="Title" style="width:100%; padding:10px; font-size:0.95rem;" value="@Model.Title" maxlength="120" required />
        </div>
        <div style="margin-bottom:10px">
            <label for="Prompt" class="note-title">Inserisci il prompt della storia</label>
            <textarea class="keep-input font-monospace" id="Prompt" name="Prompt" rows="8" style="width:100%; padding:10px; font-size:0.95rem;" required>@Model.Prompt</textarea>
        </div>
        <div id="savedStories" style="margin-bottom:10px; display:flex; gap:8px; flex-wrap:wrap"></div>
        <div id="genError" role="alert" style="color:#b00020; margin-bottom:8px; display:none"></div>

        <div style="display:flex; gap:12px; align-items:center; margin-bottom:8px">
            <div style="display:flex; align-items:center; gap:8px;">
                <label for="WriterAgentId" class="note-title" style="margin:0">Scegli writer agent (multi-step)</label>
                <select id="WriterAgentId" name="WriterAgentId" class="keep-input" style="width:320px; padding:8px" required>
                    @foreach (var agent in Model.Agents)
                    {
                        <option value="@agent.Id" selected="@(Model.WriterAgentId == agent.Id ? "selected" : null)">
                            @agent.Name
                            @if (!string.IsNullOrEmpty(agent.MultiStepTemplateName))
                            {
                                <text> [Template: @agent.MultiStepTemplateName]</text>
                            }
                        </option>
                    }
                </select>
            </div>

            <div style="margin-left:auto; display:flex; gap:8px;">
                <button type="button" id="startBtn" class="action-btn primary" style="font-weight:600; padding:8px 14px">Avvia generazione</button>
                <button type="button" id="fullPipelineBtn" class="action-btn" style="font-weight:600; padding:8px 14px; background:linear-gradient(135deg, #667eea 0%, #764ba2 100%); color:white; border:none;">🎬 Pipeline Completo</button>
            </div>
        </div>

        <!-- Progress bar for multi-step -->
        <div id="multiStepProgress" style="display:none; margin-top:12px;">
            <div class="progress" style="height:24px;">
                <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width:0%">
                    Step 0/0
                </div>
            </div>
            <div id="stepStatus" style="margin-top:6px; font-size:0.9em; color:#666;"></div>
        </div>
    </form>
    </div>
</details>

<details class="note-card generator-panel">
    <summary class="note-title generator-summary" data-icon="◉" data-subtitle="Ottimizzazione e valutazione iterativa">
        <span class="generator-summary-title">CINO Optimize Story</span>
        <span class="generator-summary-chevron">▾</span>
    </summary>
    <div class="generator-panel-body">
    <form id="cinoForm">
        @Html.AntiForgeryToken()
        <div style="margin-bottom:10px">
            <label for="CinoTitle" class="note-title">Titolo</label>
            <input class="keep-input font-monospace" id="CinoTitle" name="CinoTitle" style="width:100%; padding:10px; font-size:0.95rem;" maxlength="160" required />
        </div>
        <div style="margin-bottom:10px">
            <label for="CinoPrompt" class="note-title">Prompt iniziale (testo storia)</label>
            <textarea class="keep-input font-monospace" id="CinoPrompt" name="CinoPrompt" rows="8" style="width:100%; padding:10px; font-size:0.95rem;" required></textarea>
        </div>
        <div style="margin-bottom:10px; display:flex; align-items:center; gap:8px;">
            <input type="checkbox" id="CinoUseResponseChecker" name="CinoUseResponseChecker" value="true" @(Model.CinoUseResponseChecker ? "checked" : null) />
            <label for="CinoUseResponseChecker" class="note-title" style="margin:0">Attiva response checker</label>
        </div>
        <div id="cinoError" role="alert" style="color:#b00020; margin-bottom:8px; display:none"></div>
        <div style="display:flex; gap:8px;">
            <button type="button" id="startCinoBtn" class="action-btn primary" style="font-weight:600; padding:8px 14px">Avvia CINO</button>
        </div>
    </form>
    </div>
</details>

<details class="note-card generator-panel">
    <summary class="note-title generator-summary" data-icon="▤" data-subtitle="Da serie/episodio con writer multi-step">
        <span class="generator-summary-title">Genera episodio da serie</span>
        <span class="generator-summary-chevron">▾</span>
    </summary>
    <div class="generator-panel-body">
    <form id="seriesEpisodeForm">
        @Html.AntiForgeryToken()
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:260px; flex:1;">
                <label for="SeriesId" class="note-title">Serie</label>
                <select id="SeriesId" name="SeriesId" class="keep-input" style="width:100%; padding:8px" required>
                    @foreach (var s in Model.SeriesList)
                    {
                        <option value="@s.Id" selected="@(Model.SeriesId == s.Id ? "selected" : null)">@s.Titolo</option>
                    }
                </select>
            </div>
            <div style="min-width:220px; flex:1;">
                <label for="EpisodeId" class="note-title">Episodio</label>
                <select id="EpisodeId" name="EpisodeId" class="keep-input" style="width:100%; padding:8px" required></select>
            </div>
            <div style="min-width:260px; flex:1;">
                <label for="SeriesWriterAgentId" class="note-title">Writer agent</label>
                <select id="SeriesWriterAgentId" name="SeriesWriterAgentId" class="keep-input" style="width:100%; padding:8px" required>
                    @foreach (var agent in Model.Agents)
                    {
                        <option value="@agent.Id" selected="@(Model.SeriesWriterAgentId == agent.Id ? "selected" : null)">
                            @agent.Name
                            @if (!string.IsNullOrEmpty(agent.MultiStepTemplateName))
                            {
                                <text> [Template: @agent.MultiStepTemplateName]</text>
                            }
                        </option>
                    }
                </select>
            </div>
        </div>
        <div id="seriesEpisodeError" role="alert" style="color:#b00020; margin-bottom:8px; display:none"></div>
        <div style="display:flex; gap:8px;">
            <button type="button" id="startSeriesEpisodeBtn" class="action-btn primary" style="font-weight:600; padding:8px 14px">Avvia episodio serie</button>
        </div>
    </form>
    </div>
</details>

<details class="note-card generator-panel">
    <summary class="note-title generator-summary" data-icon="◌" data-subtitle="Serie + episodio in modalità state-driven">
        <span class="generator-summary-title">Genera episodio state-driven</span>
        <span class="generator-summary-chevron">▾</span>
    </summary>
    <div class="generator-panel-body">
    <form id="stateSeriesEpisodeForm">
        @Html.AntiForgeryToken()
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:260px; flex:1;">
                <label for="StateSeriesId" class="note-title">Serie</label>
                <select id="StateSeriesId" name="StateSeriesId" class="keep-input" style="width:100%; padding:8px" required>
                    @foreach (var s in Model.SeriesList)
                    {
                        <option value="@s.Id" selected="@(Model.StateSeriesId == s.Id ? "selected" : null)">@s.Titolo</option>
                    }
                </select>
            </div>
            <div style="min-width:220px; flex:1;">
                <label for="StateEpisodeId" class="note-title">Episodio</label>
                <select id="StateEpisodeId" name="StateEpisodeId" class="keep-input" style="width:100%; padding:8px" required></select>
            </div>
            <div style="min-width:260px; flex:1;">
                <label for="StateWriterAgentId" class="note-title">Writer agent</label>
                <select id="StateWriterAgentId" name="StateWriterAgentId" class="keep-input" style="width:100%; padding:8px" required>
                    @foreach (var agent in Model.StateWriterAgents)
                    {
                        <option value="@agent.Id" selected="@(Model.StateWriterAgentId == agent.Id ? "selected" : null)">
                            @agent.Name
                            @if (!string.IsNullOrEmpty(agent.MultiStepTemplateName))
                            {
                                <text> [Template: @agent.MultiStepTemplateName]</text>
                            }
                        </option>
                    }
                </select>
            </div>
            <div style="min-width:160px; flex:0 0 160px;">
                <label for="StateTargetMinutes" class="note-title">Minuti TTS</label>
                <input id="StateTargetMinutes" name="StateTargetMinutes" class="keep-input" style="width:100%; padding:8px" value="@Model.StateTargetMinutes" type="number" min="1" max="120" />
            </div>
        </div>
        <div style="font-size:0.9em; color:#666; margin-bottom:8px">
            Crea una storia state-driven collegata a serie/episodio e accoda il primo chunk. Il profilo narrativo viene preso dalla serie (se impostato) oppure usa il profilo default (id=1).
        </div>
        <div id="stateSeriesEpisodeError" role="alert" style="color:#b00020; margin-bottom:8px; display:none"></div>
        <div style="display:flex; gap:8px;">
            <button type="button" id="startStateSeriesEpisodeBtn" class="action-btn primary" style="font-weight:600; padding:8px 14px">Avvia episodio (state-driven)</button>
            <button type="button" id="startStateSeriesEpisodeAutoBtn" class="action-btn" style="font-weight:600; padding:8px 14px">Avvia episodio completo (~minuti TTS)</button>
        </div>
    </form>
    </div>
</details>

<details class="note-card generator-panel">
    <summary class="note-title generator-summary" data-icon="✎" data-subtitle="Storia standalone state-driven con durata target">
        <span class="generator-summary-title">Genera storia singola state-driven</span>
        <span class="generator-summary-chevron">▾</span>
    </summary>
    <div class="generator-panel-body">
    <form id="stateSingleStoryForm">
        @Html.AntiForgeryToken()
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:280px; flex:1;">
                <label for="StateSingleTitle" class="note-title">Titolo storia</label>
                <input id="StateSingleTitle" name="StateSingleTitle" class="keep-input font-monospace" style="width:100%; padding:8px" value="@Model.StateSingleTitle" maxlength="160" required />
            </div>
            <div style="min-width:220px; flex:0 0 220px;">
                <label for="StateSingleNarrativeProfileId" class="note-title">NarrativeProfileId</label>
                <select id="StateSingleNarrativeProfileId" name="StateSingleNarrativeProfileId" class="keep-input" style="width:100%; padding:8px" required>
                    @foreach (var profile in Model.NarrativeProfiles)
                    {
                        <option value="@profile.Id" selected="@(Model.StateSingleNarrativeProfileId == profile.Id ? "selected" : null)">
                            @profile.Name (@profile.Id)
                        </option>
                    }
                </select>
            </div>
            <div style="min-width:260px; flex:1;">
                <label for="StateSingleWriterAgentId" class="note-title">Writer agent</label>
                <select id="StateSingleWriterAgentId" name="StateSingleWriterAgentId" class="keep-input" style="width:100%; padding:8px" required>
                    @foreach (var agent in Model.StateWriterAgents)
                    {
                        <option value="@agent.Id" selected="@(Model.StateSingleWriterAgentId == agent.Id ? "selected" : null)">@agent.Name</option>
                    }
                </select>
            </div>
        </div>
        <div style="margin-bottom:10px;">
            <label for="StateSinglePrompt" class="note-title">Prompt/tema</label>
            <textarea id="StateSinglePrompt" name="StateSinglePrompt" class="keep-input font-monospace" rows="6" style="width:100%; padding:8px" required>@Model.StateSinglePrompt</textarea>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:170px; flex:0 0 170px;">
                <label for="StateSingleTargetMinutes" class="note-title">Lunghezza (minuti TTS)</label>
                <input id="StateSingleTargetMinutes" name="StateSingleTargetMinutes" class="keep-input" style="width:100%; padding:8px" value="@Model.StateSingleTargetMinutes" type="number" min="1" max="180" />
            </div>
            <div style="min-width:170px; flex:0 0 170px;">
                <label for="StateSingleWordsPerMinute" class="note-title">Parole/minuto</label>
                <input id="StateSingleWordsPerMinute" name="StateSingleWordsPerMinute" class="keep-input" style="width:100%; padding:8px" value="@Model.StateSingleWordsPerMinute" type="number" min="80" max="260" />
            </div>
            <div style="min-width:260px; flex:1;">
                <label for="StateSinglePlannerMode" class="note-title">Planner mode (opzionale)</label>
                <select id="StateSinglePlannerMode" name="StateSinglePlannerMode" class="keep-input" style="width:100%; padding:8px">
                    <option value="">(Nessuno)</option>
                    @foreach (var plannerMode in Model.PlannerModes)
                    {
                        <option value="@plannerMode" selected="@(string.Equals(Model.StateSinglePlannerMode, plannerMode, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                            @plannerMode
                        </option>
                    }
                </select>
            </div>
        </div>
        <div style="font-size:0.9em; color:#666; margin-bottom:8px">
            Avvia una storia standalone in modalità state-driven e genera automaticamente i chunk fino alla durata target.
        </div>
        <div id="stateSingleStoryError" role="alert" style="color:#b00020; margin-bottom:8px; display:none"></div>
        <div style="display:flex; gap:8px;">
            <button type="button" id="startStateSingleStoryBtn" class="action-btn primary" style="font-weight:600; padding:8px 14px">Avvia storia singola</button>
        </div>
    </form>
    </div>
</details>

<details class="note-card generator-panel">
    <summary class="note-title generator-summary" data-icon="⟲" data-subtitle="Riprende una story state-driven da StoryId">
        <span class="generator-summary-title">Continua storia state-driven</span>
        <span class="generator-summary-chevron">▾</span>
    </summary>
    <div class="generator-panel-body">
    <form id="stateNextChunkForm">
        @Html.AntiForgeryToken()
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:10px;">
            <div style="min-width:220px; flex:0 0 220px;">
                <label for="StateStoryId" class="note-title">StoryId</label>
                <input id="StateStoryId" name="StateStoryId" class="keep-input font-monospace" style="width:100%; padding:8px" value="@Model.StateStoryId" placeholder="es. 123" required />
            </div>
            <div style="min-width:260px; flex:1;">
                <label for="StateNextChunkWriterAgentId" class="note-title">Writer agent</label>
                <select id="StateNextChunkWriterAgentId" name="StateNextChunkWriterAgentId" class="keep-input" style="width:100%; padding:8px" required>
                    @foreach (var agent in Model.StateWriterAgents)
                    {
                        <option value="@agent.Id" selected="@(Model.StateNextChunkWriterAgentId == agent.Id ? "selected" : null)">@agent.Name</option>
                    }
                </select>
            </div>
        </div>
        <div style="font-size:0.9em; color:#666; margin-bottom:8px">
            Usa lo StoryId creato dallo start state-driven e genera il chunk successivo.
        </div>
        <div id="stateNextChunkError" role="alert" style="color:#b00020; margin-bottom:8px; display:none"></div>
        <div style="display:flex; gap:8px;">
            <button type="button" id="startStateNextChunkBtn" class="action-btn primary" style="font-weight:600; padding:8px 14px">Genera chunk successivo</button>
        </div>
    </form>
    </div>
</details>

</div>

<hr />
<h2>Stato generazione (live):</h2>
<div id="statusArea">
    <div id="statusPre" class="status-list"><div class="status-msg">Pronto.</div></div>
</div>

<script src="~/lib/signalr/signalr.min.js"></script>
<script>
    const seriesEpisodes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SeriesEpisodes));
    const startBtn = document.getElementById('startBtn');
    const statusPre = document.getElementById('statusPre');
    const seriesIdSelect = document.getElementById('SeriesId');
    const episodeIdSelect = document.getElementById('EpisodeId');
    const startSeriesEpisodeBtn = document.getElementById('startSeriesEpisodeBtn');
    const seriesEpisodeError = document.getElementById('seriesEpisodeError');

    const stateSeriesIdSelect = document.getElementById('StateSeriesId');
    const stateEpisodeIdSelect = document.getElementById('StateEpisodeId');
    const startStateSeriesEpisodeBtn = document.getElementById('startStateSeriesEpisodeBtn');
    const startStateSeriesEpisodeAutoBtn = document.getElementById('startStateSeriesEpisodeAutoBtn');
    const stateSeriesEpisodeError = document.getElementById('stateSeriesEpisodeError');
    const startStateSingleStoryBtn = document.getElementById('startStateSingleStoryBtn');
    const stateSingleStoryError = document.getElementById('stateSingleStoryError');

    const stateStoryIdInput = document.getElementById('StateStoryId');
    const startStateNextChunkBtn = document.getElementById('startStateNextChunkBtn');
    const stateNextChunkError = document.getElementById('stateNextChunkError');
    const startCinoBtn = document.getElementById('startCinoBtn');
    const cinoError = document.getElementById('cinoError');
    const startNreBtn = document.getElementById('startNreBtn');
    const suggestNrePromptBtn = document.getElementById('suggestNrePromptBtn');
    const suggestNreMilitaryPromptBtn = document.getElementById('suggestNreMilitaryPromptBtn');
    const suggestNreReligiousPromptBtn = document.getElementById('suggestNreReligiousPromptBtn');
    const suggestNrePromptSpinner = document.getElementById('suggestNrePromptSpinner');
    const suggestNrePromptBtnText = document.getElementById('suggestNrePromptBtnText');
    const nreError = document.getElementById('nreError');
    let pollInterval = null;
    let connection = null;

    // Card behavior: keep one generation panel expanded at a time.
    document.querySelectorAll('#generationPanels .generator-panel').forEach(panel => {
        panel.addEventListener('toggle', () => {
            if (!panel.open) return;
            document.querySelectorAll('#generationPanels .generator-panel').forEach(other => {
                if (other !== panel) other.open = false;
            });
        });
    });

    if (startNreBtn) {
        startNreBtn.addEventListener('click', async () => {
            if (nreError) {
                nreError.textContent = '';
                nreError.style.display = 'none';
            }

            const method = document.getElementById('NreMethod')?.value || 'state_driven';
            const maxSteps = document.getElementById('NreMaxSteps')?.value || '10';
            const theme = document.getElementById('NreTheme')?.value || '';
            const genre = document.getElementById('NreGenre')?.value || '';
            const tone = document.getElementById('NreTone')?.value || '';
            const snapshot = document.getElementById('NreSnapshotOnFailure')?.checked ? 'true' : 'false';

            if (!theme.trim()) {
                if (nreError) {
                    nreError.textContent = 'Inserisci almeno il Tema per NRE.';
                    nreError.style.display = 'block';
                }
                return;
            }

            clearMessages();
            appendMessage('🧠 Avvio NRE...');

            const form = document.getElementById('nreForm');
            const fd = new FormData(form);
            const res = await fetch('?handler=StartNre', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (nreError) {
                    nreError.textContent = text;
                    nreError.style.display = 'block';
                }
                appendMessage('Errore avvio NRE: ' + text, 'error');
                return;
            }

            const data = await res.json();
            const id = data.id;
            try { localStorage.setItem('lastGenId', id); } catch { }
            saveNreStoryToCookie();
            appendMessage(`🟢 NRE avviato. id: ${id}`);
            appendMessage(`Parametri: method=${method}; maxSteps=${maxSteps}; genre=${genre || '-'}; tone=${tone || '-'}; snapshotOnFailure=${snapshot}`);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
        });
    }

    if (suggestNrePromptBtn) {
        suggestNrePromptBtn.addEventListener('click', async () => {
            await requestNreSuggestion('?handler=StartNrePromptSuggestion', '💡 Richiesta suggerimento NRE (batch)...');
        });
    }

    if (suggestNreMilitaryPromptBtn) {
        suggestNreMilitaryPromptBtn.addEventListener('click', async () => {
            await requestNreSuggestion(
                '?handler=StartNrePromptSuggestionItalianSpaceFleet',
                '🚀 Richiesta suggerimento NRE militare (flotta spaziale italiana)...');
        });
    }

    if (suggestNreReligiousPromptBtn) {
        suggestNreReligiousPromptBtn.addEventListener('click', async () => {
            await requestNreSuggestion(
                '?handler=StartNrePromptSuggestionReligiousVatican',
                '🕯️ Richiesta suggerimento NRE religioso (Vaticano horror)...');
        });
    }

    async function requestNreSuggestion(url, startMessage) {
        if (nreError) {
            nreError.textContent = '';
            nreError.style.display = 'none';
        }

        setNreSuggestionLoading(true);
        clearMessages();
        appendMessage(startMessage);
        try {
            const form = document.getElementById('nreForm');
            const fd = new FormData(form);
            const res = await fetch(url, { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (nreError) {
                    nreError.textContent = text;
                    nreError.style.display = 'block';
                }
                appendMessage('Errore suggerimento NRE: ' + text, 'error');
                return;
            }

            const data = await res.json();
            const id = data.id;
            try { localStorage.setItem('lastGenId', id); } catch { }
            appendMessage(`🟢 Suggerimento NRE accodato. id: ${id}`);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
            await waitAndApplyNreSuggestion(id);
        } finally {
            setNreSuggestionLoading(false);
        }
    }

    function setNreSuggestionLoading(isLoading) {
        if (!suggestNrePromptBtn) return;
        suggestNrePromptBtn.disabled = !!isLoading;
        suggestNrePromptBtn.style.opacity = isLoading ? '0.75' : '';
        suggestNrePromptBtn.style.cursor = isLoading ? 'wait' : '';
        if (suggestNreMilitaryPromptBtn) {
            suggestNreMilitaryPromptBtn.disabled = !!isLoading;
            suggestNreMilitaryPromptBtn.style.opacity = isLoading ? '0.75' : '';
            suggestNreMilitaryPromptBtn.style.cursor = isLoading ? 'wait' : '';
        }
        if (suggestNreReligiousPromptBtn) {
            suggestNreReligiousPromptBtn.disabled = !!isLoading;
            suggestNreReligiousPromptBtn.style.opacity = isLoading ? '0.75' : '';
            suggestNreReligiousPromptBtn.style.cursor = isLoading ? 'wait' : '';
        }
        if (suggestNrePromptSpinner) {
            suggestNrePromptSpinner.style.display = isLoading ? 'inline-block' : 'none';
        }
        if (suggestNrePromptBtnText) {
            suggestNrePromptBtnText.textContent = isLoading
                ? 'Generazione suggerimento...'
                : 'Suggerisci titolo+prompt';
        }
    }

    async function waitAndApplyNreSuggestion(id) {
        const started = Date.now();
        const timeoutMs = 120000;
        while (Date.now() - started < timeoutMs) {
            try {
                const p = await fetch(`?handler=progress&id=${encodeURIComponent(id)}`);
                if (p.ok) {
                    const js = await p.json();
                    if (js && js.completed) {
                        if (!js.result) {
                            appendMessage('Suggerimento NRE completato senza payload.', 'warning');
                            return;
                        }

                        let payload = null;
                        try {
                            payload = JSON.parse(js.result);
                        } catch (e) {
                            appendMessage('Payload suggerimento NRE non è JSON valido.', 'warning');
                            return;
                        }

        applyNreSuggestionToForm(payload);
        renderSavedNreButtons();
        appendMessage('✅ Campi NRE aggiornati con proposta automatica.', 'success');
        return;
                    }
                }
            } catch (e) {
                console.error('waitAndApplyNreSuggestion', e);
            }
            await new Promise(r => setTimeout(r, 1200));
        }
        appendMessage('Timeout attesa suggerimento NRE.', 'warning');
    }

    function applyNreSuggestionToForm(payload) {
        if (!payload || typeof payload !== 'object') return;
        const setVal = (id, value) => {
            const el = document.getElementById(id);
            if (!el) return;
            el.value = (value ?? '').toString();
        };
        setVal('NreTitle', payload.title);
        setVal('NreTheme', payload.theme);
        setVal('NreSetting', payload.setting);
        setVal('NreGenre', payload.genre);
        setVal('NreTone', payload.tone);
        setVal('NreConstraints', payload.constraints);
        setVal('NreResourceHints', payload.resource_hints ?? payload.resourceHints);
        setVal('NrePrompt', payload.prompt);
    }

    // helper: fetch and render history for a genId
    async function loadHistory(id) {
        try {
            const p = await fetch(`?handler=progress&id=${encodeURIComponent(id)}`);
            if (!p.ok) return;
            const js = await p.json();
            renderMessages(js.messages);
            if (js.completed) {
                appendMessage('✅ Completato.');
                if (js.result) appendMessage('Risultato finale (estratto):\n' + js.result.substring(0,1000), 'result');
            }
        } catch (e) { console.error(e); }
    }

    // open a SignalR connection and join a group for genId
    async function connectSignalRAndJoin(genId) {
        try {
            // prefer to reuse the global appSignalR connection if available
            if (window.appSignalR && window.appSignalR.connection) {
                connection = window.appSignalR.connection;
                connection.on('ProgressAppended', (id, message, extraClass) => {
                    if (id !== genId) return;
                    appendMessage(message, extraClass);
                });
                connection.on('ProgressCompleted', (id, finalResult) => {
                    if (id !== genId) return;
                    appendMessage('✅ Completato.');
                    if (finalResult) appendMessage('Risultato finale (estratto):\n' + (finalResult.substring ? finalResult.substring(0,1000) : finalResult), 'result');
                });
                // Multi-step events
                connection.on('StepProgress', (id, current, max, stepDesc) => {
                    if (id !== genId) return;
                    updateProgressBar(current, max, stepDesc);
                });
                connection.on('StepRetry', (id, retryCount, reason) => {
                    if (id !== genId) return;
                    appendMessage(`🔄 Retry ${retryCount}: ${reason}`, 'warning');
                });
                connection.on('StepComplete', (id, stepNum) => {
                    if (id !== genId) return;
                    appendMessage(`✅ Step ${stepNum} completed`, 'success');
                });
                connection.on('TaskComplete', (id, status) => {
                    if (id !== genId) return;
                    hideProgressBar();
                    if (status === 'completed') {
                        appendMessage('✅ Task completed successfully', 'success');
                    } else if (status === 'failed') {
                        appendMessage('❌ Task failed', 'error');
                    } else if (status === 'cancelled') {
                        appendMessage('⚠️ Task cancelled', 'warning');
                    }
                });
                await window.appSignalR.joinGroup(genId);
                return;
            }
            if (!window.signalR) {
                console.warn('SignalR not available');
                return;
            }
            connection = new signalR.HubConnectionBuilder().withUrl('/progressHub').withAutomaticReconnect().build();

            connection.on('ProgressAppended', (id, message, extraClass) => {
                if (id !== genId) return;
                appendMessage(message, extraClass);
            });
            connection.on('ProgressCompleted', (id, finalResult) => {
                if (id !== genId) return;
                appendMessage('✅ Completato.');
                if (finalResult) appendMessage('Risultato finale (estratto):\n' + (finalResult.substring ? finalResult.substring(0,1000) : finalResult), 'result');
            });
            // Multi-step events
            connection.on('StepProgress', (id, current, max, stepDesc) => {
                if (id !== genId) return;
                updateProgressBar(current, max, stepDesc);
            });
            connection.on('StepRetry', (id, retryCount, reason) => {
                if (id !== genId) return;
                appendMessage(`🔄 Retry ${retryCount}: ${reason}`, 'warning');
            });
            connection.on('StepComplete', (id, stepNum) => {
                if (id !== genId) return;
                appendMessage(`✅ Step ${stepNum} completed`, 'success');
            });
            connection.on('TaskComplete', (id, status) => {
                if (id !== genId) return;
                hideProgressBar();
                if (status === 'completed') {
                    appendMessage('✅ Task completed successfully', 'success');
                } else if (status === 'failed') {
                    appendMessage('❌ Task failed', 'error');
                } else if (status === 'cancelled') {
                    appendMessage('⚠️ Task cancelled', 'warning');
                }
            });

            await connection.start();
            await connection.invoke('JoinGroup', genId);
        } catch (e) { console.error('SignalR connect error', e); }
    }

    startBtn.addEventListener('click', async () => {
        const prompt = document.getElementById('Prompt').value;
        const genError = document.getElementById('genError');
        if (!prompt || prompt.trim().length === 0) {
            if (genError) {
                genError.textContent = 'Inserisci il prompt';
                genError.style.display = 'block';
            }
            document.getElementById('Prompt').focus();
            return;
        } else if (genError) {
            genError.textContent = '';
            genError.style.display = 'none';
        }

        // save title/prompt to cookie-based history
        saveStoryToCookie();
        clearMessages();
        appendMessage('🟡 Avvio...');
    // send start request (include antiforgery token automatically by using the form)
    const form = document.getElementById('genForm');
    const fd = new FormData(form);
    const res = await fetch('?handler=start', { method: 'POST', body: fd });
        if (!res.ok) {
            const text = await res.text();
            appendMessage('Errore avvio: ' + text, 'error');
            return;
        }
        const data = await res.json();
        const id = data.id;
        // persist last gen id so user can come back to page and reconnect
        try { localStorage.setItem('lastGenId', id); } catch { }
        appendMessage('🟢 Generazione avviata. id: ' + id);
        // load history and start SignalR for live updates
        await loadHistory(id);
        await connectSignalRAndJoin(id);
    });

    function renderEpisodeOptions() {
        if (!seriesIdSelect || !episodeIdSelect) return;
        const serieId = parseInt(seriesIdSelect.value || '0', 10);
        episodeIdSelect.innerHTML = '';
        const items = seriesEpisodes.filter(e => e.SerieId === serieId);
        if (items.length === 0) {
            const opt = document.createElement('option');
            opt.value = '';
            opt.textContent = 'Nessun episodio';
            episodeIdSelect.appendChild(opt);
            return;
        }
        items.forEach(ep => {
            const opt = document.createElement('option');
            opt.value = ep.Id;
            const title = ep.Title ? ` - ${ep.Title}` : '';
            opt.textContent = `Ep ${ep.Number}${title}`;
            if (ep.Id === @Model.EpisodeId) opt.selected = true;
            episodeIdSelect.appendChild(opt);
        });
    }

    function renderStateEpisodeOptions() {
        if (!stateSeriesIdSelect || !stateEpisodeIdSelect) return;
        const serieId = parseInt(stateSeriesIdSelect.value || '0', 10);
        stateEpisodeIdSelect.innerHTML = '';
        const items = seriesEpisodes.filter(e => e.SerieId === serieId);
        if (items.length === 0) {
            const opt = document.createElement('option');
            opt.value = '';
            opt.textContent = 'Nessun episodio';
            stateEpisodeIdSelect.appendChild(opt);
            return;
        }
        items.forEach(ep => {
            const opt = document.createElement('option');
            opt.value = ep.Id;
            const title = ep.Title ? ` - ${ep.Title}` : '';
            opt.textContent = `Ep ${ep.Number}${title}`;
            if (ep.Id === @Model.StateEpisodeId) opt.selected = true;
            stateEpisodeIdSelect.appendChild(opt);
        });
    }

    if (seriesIdSelect) {
        seriesIdSelect.addEventListener('change', renderEpisodeOptions);
        renderEpisodeOptions();
    }

    if (stateSeriesIdSelect) {
        stateSeriesIdSelect.addEventListener('change', renderStateEpisodeOptions);
        renderStateEpisodeOptions();
    }

    if (startSeriesEpisodeBtn) {
        startSeriesEpisodeBtn.addEventListener('click', async () => {
            if (seriesEpisodeError) {
                seriesEpisodeError.textContent = '';
                seriesEpisodeError.style.display = 'none';
            }
            clearMessages();
            appendMessage('Avvio episodio serie...');

            const form = document.getElementById('seriesEpisodeForm');
            const fd = new FormData(form);
            const res = await fetch('?handler=StartSeriesEpisode', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (seriesEpisodeError) {
                    seriesEpisodeError.textContent = text;
                    seriesEpisodeError.style.display = 'block';
                }
                appendMessage('Errore avvio: ' + text, 'error');
                return;
            }
            const data = await res.json();
            const id = data.id;
            try { localStorage.setItem('lastGenId', id); } catch { }
            appendMessage('Generazione episodio avviata. id: ' + id);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
        });
    }

    if (startStateSeriesEpisodeBtn) {
        startStateSeriesEpisodeBtn.addEventListener('click', async () => {
            if (stateSeriesEpisodeError) {
                stateSeriesEpisodeError.textContent = '';
                stateSeriesEpisodeError.style.display = 'none';
            }
            clearMessages();
            appendMessage('Avvio episodio state-driven...');

            const form = document.getElementById('stateSeriesEpisodeForm');
            const fd = new FormData(form);
            const res = await fetch('?handler=StartStateSeriesEpisode', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (stateSeriesEpisodeError) {
                    stateSeriesEpisodeError.textContent = text;
                    stateSeriesEpisodeError.style.display = 'block';
                }
                appendMessage('Errore avvio: ' + text, 'error');
                return;
            }
            const data = await res.json();
            const id = data.id;
            const storyId = data.storyId;
            try { localStorage.setItem('lastGenId', id); } catch { }
            if (storyId) {
                try { localStorage.setItem('lastStateStoryId', storyId.toString()); } catch { }
                if (stateStoryIdInput) stateStoryIdInput.value = storyId;
                appendMessage('StoryId: ' + storyId);
            }
            appendMessage('Generazione episodio state-driven avviata. id: ' + id);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
        });
    }

    if (startStateSeriesEpisodeAutoBtn) {
        startStateSeriesEpisodeAutoBtn.addEventListener('click', async () => {
            if (stateSeriesEpisodeError) {
                stateSeriesEpisodeError.textContent = '';
                stateSeriesEpisodeError.style.display = 'none';
            }
            clearMessages();
            appendMessage('Avvio episodio completo state-driven...');

            const form = document.getElementById('stateSeriesEpisodeForm');
            const fd = new FormData(form);
            const res = await fetch('?handler=StartStateSeriesEpisodeAuto', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (stateSeriesEpisodeError) {
                    stateSeriesEpisodeError.textContent = text;
                    stateSeriesEpisodeError.style.display = 'block';
                }
                appendMessage('Errore avvio: ' + text, 'error');
                return;
            }
            const data = await res.json();
            const id = data.id;
            const storyId = data.storyId;
            try { localStorage.setItem('lastGenId', id); } catch { }
            if (storyId) {
                try { localStorage.setItem('lastStateStoryId', storyId.toString()); } catch { }
                if (stateStoryIdInput) stateStoryIdInput.value = storyId;
                appendMessage('StoryId: ' + storyId);
            }
            appendMessage('Generazione episodio completo accodata. id: ' + id);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
        });
    }

    if (startStateNextChunkBtn) {
        startStateNextChunkBtn.addEventListener('click', async () => {
            if (stateNextChunkError) {
                stateNextChunkError.textContent = '';
                stateNextChunkError.style.display = 'none';
            }
            clearMessages();
            appendMessage('Generazione chunk successivo...');

            const form = document.getElementById('stateNextChunkForm');
            const fd = new FormData(form);
            const res = await fetch('?handler=StateNextChunk', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (stateNextChunkError) {
                    stateNextChunkError.textContent = text;
                    stateNextChunkError.style.display = 'block';
                }
                appendMessage('Errore: ' + text, 'error');
                return;
            }

            const data = await res.json();
            const id = data.id;
            try { localStorage.setItem('lastGenId', id); } catch { }
            appendMessage('Chunk accodato. id: ' + id);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
        });
    }

    if (startStateSingleStoryBtn) {
        startStateSingleStoryBtn.addEventListener('click', async () => {
            if (stateSingleStoryError) {
                stateSingleStoryError.textContent = '';
                stateSingleStoryError.style.display = 'none';
            }
            clearMessages();
            appendMessage('Avvio storia singola state-driven...');

            const form = document.getElementById('stateSingleStoryForm');
            const fd = new FormData(form);
            const res = await fetch('?handler=StartStateSingleStoryAuto', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (stateSingleStoryError) {
                    stateSingleStoryError.textContent = text;
                    stateSingleStoryError.style.display = 'block';
                }
                appendMessage('Errore avvio: ' + text, 'error');
                return;
            }

            const data = await res.json();
            const id = data.id;
            try { localStorage.setItem('lastGenId', id); } catch { }
            appendMessage('Storia singola state-driven accodata. id: ' + id);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
        });
    }

    if (startCinoBtn) {
        startCinoBtn.addEventListener('click', async () => {
            if (cinoError) {
                cinoError.textContent = '';
                cinoError.style.display = 'none';
            }
            clearMessages();
            appendMessage('Avvio CINO...');

            const form = document.getElementById('cinoForm');
            const fd = new FormData(form);
            const res = await fetch('?handler=StartCinoOptimize', { method: 'POST', body: fd });
            if (!res.ok) {
                const text = await res.text();
                if (cinoError) {
                    cinoError.textContent = text;
                    cinoError.style.display = 'block';
                }
                appendMessage('Errore avvio: ' + text, 'error');
                return;
            }

            const data = await res.json();
            const id = data.id;
            try { localStorage.setItem('lastGenId', id); } catch { }
            appendMessage('CINO avviato. id: ' + id);
            await loadHistory(id);
            await connectSignalRAndJoin(id);
        });
    }

    // Full Pipeline button - generates with all writers, evaluates, selects best, runs full audio pipeline
    const fullPipelineBtn = document.getElementById('fullPipelineBtn');
    fullPipelineBtn.addEventListener('click', async () => {
        const prompt = document.getElementById('Prompt').value;
        const genError = document.getElementById('genError');
        if (!prompt || prompt.trim().length === 0) {
            if (genError) {
                genError.textContent = 'Inserisci il prompt';
                genError.style.display = 'block';
            }
            document.getElementById('Prompt').focus();
            return;
        } else if (genError) {
            genError.textContent = '';
            genError.style.display = 'none';
        }

        // save title/prompt to cookie-based history
        saveStoryToCookie();
        clearMessages();
        appendMessage('🎬 Avvio pipeline completo...');
        appendMessage('📝 Verrà generata una storia con tutti i writer attivi');
        appendMessage('🔍 Le storie verranno valutate e la migliore selezionata');
        appendMessage('🔊 Poi verrà eseguito il pipeline audio completo');

        // send start request for full pipeline
        const form = document.getElementById('genForm');
        const fd = new FormData(form);
        const res = await fetch('?handler=StartFullPipeline', { method: 'POST', body: fd });
        if (!res.ok) {
            const text = await res.text();
            appendMessage('Errore avvio: ' + text, 'error');
            return;
        }
        const data = await res.json();
        const id = data.id;
        // persist last gen id so user can come back to page and reconnect
        try { localStorage.setItem('lastGenId', id); } catch { }
        appendMessage('🟢 Pipeline completo avviato. id: ' + id);
        // load history and start SignalR for live updates
        await loadHistory(id);
        await connectSignalRAndJoin(id);
    });

    // on page load, if there's a lastGenId in localStorage, reattach to it (so the page is persistent)
    (async () => {
        // render any saved stories from cookie
        renderSavedButtons();
        renderSavedNreButtons();
        try {
            const existing = localStorage.getItem('lastGenId');
            if (existing) {
                clearMessages();
                appendMessage('🔄 Ricollegamento alla generazione ' + existing + '...');
                await loadHistory(existing);
                await connectSignalRAndJoin(existing);
            }

            const lastStateStoryId = localStorage.getItem('lastStateStoryId');
            if (lastStateStoryId && stateStoryIdInput && (!stateStoryIdInput.value || stateStoryIdInput.value.trim().length === 0)) {
                stateStoryIdInput.value = lastStateStoryId;
            }
        } catch (e) { console.error(e); }
    })();
    // message helpers
    function clearMessages() { statusPre.innerHTML = ''; }
    function appendMessage(msg, extraClass) {
        const el = document.createElement('div');
        el.className = 'status-msg' + (extraClass ? (' ' + extraClass) : '');
        
        // Apply pastel colors for success/error
        if (extraClass === 'success') {
            el.style.backgroundColor = '#d4edda';
            el.style.color = '#155724';
            el.style.padding = '8px';
            el.style.borderRadius = '4px';
            el.style.marginBottom = '4px';
        } else if (extraClass === 'error') {
            el.style.backgroundColor = '#f8d7da';
            el.style.color = '#721c24';
            el.style.padding = '8px';
            el.style.borderRadius = '4px';
            el.style.marginBottom = '4px';
        } else if (extraClass === 'warning') {
            el.style.backgroundColor = '#fff3cd';
            el.style.color = '#856404';
            el.style.padding = '8px';
            el.style.borderRadius = '4px';
            el.style.marginBottom = '4px';
        }
        
        el.textContent = msg;
        statusPre.appendChild(el);
    }
    function renderMessages(messages) { clearMessages(); if (!messages) return; messages.forEach(m => appendMessage(m)); }

    // Progress bar helpers
    function updateProgressBar(current, max, stepDesc) {
        const progressDiv = document.getElementById('multiStepProgress');
        const progressBar = document.getElementById('progressBar');
        const stepStatus = document.getElementById('stepStatus');
        
        if (progressDiv && progressBar && stepStatus) {
            progressDiv.style.display = 'block';
            const pct = Math.round((current / max) * 100);
            progressBar.style.width = pct + '%';
            progressBar.textContent = `Step ${current}/${max}`;
            stepStatus.textContent = stepDesc;
        }
    }

    function hideProgressBar() {
        const progressDiv = document.getElementById('multiStepProgress');
        if (progressDiv) {
            progressDiv.style.display = 'none';
        }
    }

    // --- Saved stories (cookie) helpers ---
    function getCookie(name) {
        const v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
        return v ? decodeURIComponent(v.pop()) : '';
    }
    function setCookie(name, value, days) {
        const d = new Date();
        d.setTime(d.getTime() + (days*24*60*60*1000));
        document.cookie = name + '=' + encodeURIComponent(value) + ';path=/;expires=' + d.toUTCString();
    }
    function getSavedStories() {
        const raw = getCookie('tg_history');
        if (!raw) return [];
        try { return JSON.parse(raw); } catch (e) { return []; }
    }
    function saveStoryToCookie() {
        try {
            const titleEl = document.getElementById('Title');
            const promptEl = document.getElementById('Prompt');
            if (!titleEl || !promptEl) return;
            const title = titleEl.value ? titleEl.value.trim() : '';
            const prompt = promptEl.value ? promptEl.value : '';
            if (!title) return; // don't save empty titles
            const arr = getSavedStories();
            // if title exists, remove it (we'll re-add to front)
            const idx = arr.findIndex(x => x.title === title);
            if (idx >= 0) arr.splice(idx, 1);
            arr.unshift({ title: title, prompt: prompt });
            // keep max 10
            const sliced = arr.slice(0, 10);
            setCookie('tg_history', JSON.stringify(sliced), 365);
            renderSavedButtons();
        } catch (e) { console.error('saveStoryToCookie', e); }
    }
    function renderSavedButtons() {
        const container = document.getElementById('savedStories');
        if (!container) return;
        container.innerHTML = '';
        const arr = getSavedStories();
        if (!arr || arr.length === 0) return;
        arr.forEach(item => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'action-btn';
            btn.style.padding = '6px 10px';
            btn.style.background = '#f1f5f9';
            btn.style.border = '1px solid #e2e8f0';
            btn.style.borderRadius = '6px';
            btn.style.cursor = 'pointer';
            btn.textContent = item.title;
            btn.title = 'Ripristina titolo e prompt salvati';
            btn.addEventListener('click', () => {
                const titleEl = document.getElementById('Title');
                const promptEl = document.getElementById('Prompt');
                if (titleEl) titleEl.value = item.title;
                if (promptEl) promptEl.value = item.prompt;
            });
            container.appendChild(btn);
        });
    }

    // --- Saved NRE prompts (cookie) helpers ---
    function getSavedNreStories() {
        const raw = getCookie('tg_nre_history');
        if (!raw) return [];
        try { return JSON.parse(raw); } catch (e) { return []; }
    }

    function saveNreStoryToCookie() {
        try {
            const titleEl = document.getElementById('NreTitle');
            const themeEl = document.getElementById('NreTheme');
            const settingEl = document.getElementById('NreSetting');
            const genreEl = document.getElementById('NreGenre');
            const toneEl = document.getElementById('NreTone');
            const constraintsEl = document.getElementById('NreConstraints');
            const resourceHintsEl = document.getElementById('NreResourceHints');
            if (!themeEl) return;

            const item = {
                title: (titleEl?.value || '').trim(),
                theme: (themeEl?.value || '').trim(),
                setting: (settingEl?.value || '').trim(),
                genre: (genreEl?.value || '').trim(),
                tone: (toneEl?.value || '').trim(),
                constraints: (constraintsEl?.value || '').trim(),
                resourceHints: (resourceHintsEl?.value || '').trim()
            };

            if (!item.theme) return;

            const labelBase = item.title || item.theme;
            const label = labelBase.length > 40 ? (labelBase.substring(0, 40) + '...') : labelBase;
            const arr = getSavedNreStories();

            const duplicateIdx = arr.findIndex(x =>
                (x.title || '') === item.title &&
                (x.theme || '') === item.theme &&
                (x.setting || '') === item.setting &&
                (x.genre || '') === item.genre &&
                (x.tone || '') === item.tone &&
                (x.constraints || '') === item.constraints &&
                (x.resourceHints || '') === item.resourceHints);
            if (duplicateIdx >= 0) arr.splice(duplicateIdx, 1);

            arr.unshift({ ...item, label });
            setCookie('tg_nre_history', JSON.stringify(arr.slice(0, 10)), 365);
            renderSavedNreButtons();
        } catch (e) { console.error('saveNreStoryToCookie', e); }
    }

    function renderSavedNreButtons() {
        const container = document.getElementById('savedNreStories');
        if (!container) return;
        container.innerHTML = '';
        const arr = getSavedNreStories();
        if (!arr || arr.length === 0) return;

        arr.forEach(item => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'action-btn';
            btn.style.padding = '6px 10px';
            btn.style.background = '#eef3f0';
            btn.style.border = '1px solid #d6e3da';
            btn.style.borderRadius = '6px';
            btn.style.cursor = 'pointer';
            btn.textContent = item.label || item.title || 'NRE';
            btn.title = 'Ripristina campi NRE salvati';
            btn.addEventListener('click', () => {
                const setVal = (id, value) => {
                    const el = document.getElementById(id);
                    if (el) el.value = value || '';
                };
                setVal('NreTitle', item.title);
                setVal('NreTheme', item.theme);
                setVal('NreSetting', item.setting);
                setVal('NreGenre', item.genre);
                setVal('NreTone', item.tone);
                setVal('NreConstraints', item.constraints);
                setVal('NreResourceHints', item.resourceHints);
            });
            container.appendChild(btn);
        });
    }

    // hide error when user edits prompt
    const promptInput = document.getElementById('Prompt');
    if (promptInput) {
        promptInput.addEventListener('input', () => {
            const genError = document.getElementById('genError');
            if (genError) { genError.textContent = ''; genError.style.display = 'none'; }
        });
    }
</script>
