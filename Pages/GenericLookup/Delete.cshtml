@page "{id:long}"
@model TinyGenerator.Pages.GenericLookup.DeleteModel
@{
    ViewData["Title"] = "Elimina Generic Lookup";
    ViewData["PageDescription"] = "Conferma eliminazione record";
}

<div class="container-fluid py-3">
    <div class="card border-danger">
        <div class="card-body">
            <h5 class="card-title text-danger mb-3">Confermi l'eliminazione?</h5>

            <dl class="row mb-0">
                <dt class="col-sm-2">Id</dt>
                <dd class="col-sm-10">@Model.Item.Id</dd>

                <dt class="col-sm-2">Type</dt>
                <dd class="col-sm-10">@Model.Item.Type</dd>

                <dt class="col-sm-2">Code</dt>
                <dd class="col-sm-10">@Model.Item.Code</dd>

                <dt class="col-sm-2">Value</dt>
                <dd class="col-sm-10">@Model.Item.Value</dd>
            </dl>

            <form method="post" class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-danger">Elimina</button>
                <a asp-page="./Index" class="btn btn-outline-secondary">Annulla</a>
            </form>
        </div>
    </div>
</div>

