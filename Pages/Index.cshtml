@page
@model TinyGenerator.Pages.IndexModel
@{
    ViewData["Title"] = "TinyGenerator";
}

<style>
    .kpi-card {
        background: #f8f9fa;
        border: 2px solid #343a40;
        border-radius: 12px;
        padding: 1.5rem;
        color: #212529;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .kpi-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }
    .kpi-value {
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.1;
        color: #212529;
    }
    .kpi-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6c757d;
    }
    .kpi-icon {
        font-size: 2rem;
        color: #6c757d;
    }
    .kpi-card.kpi-compact {
        padding: 0.7rem 0.9rem;
        border-width: 1px;
        min-height: 92px;
    }
    .kpi-card[data-bs-toggle="tooltip"] {
        cursor: help;
    }
    .kpi-card.kpi-compact .kpi-value {
        font-size: 1.35rem;
    }
    .kpi-card.kpi-compact .kpi-label {
        font-size: 0.74rem;
    }
    .kpi-card.kpi-compact .kpi-icon {
        font-size: 1.2rem;
        opacity: 0.8;
    }
    .kpi-card.kpi-brown-soft {
        background: #f4ede4;
        border-color: #b7a58f;
    }
    .kpi-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }
    .ranking-table {
        background: #f8f9fa;
        border: 2px solid #343a40;
        border-radius: 12px;
        overflow: hidden;
    }
    .ranking-table th {
        background: #e9ecef;
        color: #495057;
        font-weight: 500;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border: none;
    }
    .ranking-table td {
        background: #f8f9fa;
        color: #212529;
        border-color: #dee2e6;
        vertical-align: middle;
    }
    .ranking-table tbody tr:hover td {
        background: #e9ecef;
    }
    .rank-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .rank-1 { background: #ffd700; color: #000; }
    .rank-2 { background: #c0c0c0; color: #000; }
    .rank-3 { background: #cd7f32; color: #fff; }
    .rank-other { background: #f1f3f5; color: #495057; }
    .score-badge {
        background: #e9ecef;
        border: 1px solid #adb5bd;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        font-weight: 600;
        color: #212529;
    }
    .section-title {
        color: #495057;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #343a40;
    }
    .report-card {
        background: #f8f9fa;
        border: 2px solid #343a40;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }
    .report-meta {
        font-size: 0.8rem;
        color: #6c757d;
    }
    .report-title {
        font-weight: 600;
        color: #212529;
    }
    .report-badge {
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border: 1px solid #adb5bd;
        background: #e9ecef;
        color: #212529;
    }
    .report-badge.sev-error { background: #ffe3e3; border-color: #ffa8a8; color: #c92a2a; }
    .report-badge.sev-warning { background: #fff4e6; border-color: #ffd8a8; color: #e67700; }
    .report-badge.sev-critical { background: #fff5f5; border-color: #ffc9c9; color: #a61e4d; }
    .report-badge.sev-info { background: #e7f5ff; border-color: #a5d8ff; color: #1c7ed6; }
    .chart-card {
        background: #f8f9fa;
        border: 2px solid #343a40;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        min-height: 360px;
    }
    .chart-wrap {
        height: 260px;
        position: relative;
    }
    .chart-legend-list {
        list-style: none;
        padding: 0;
        margin: 0.75rem 0 0;
        columns: 1;
    }
    .chart-legend-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        font-size: 0.86rem;
        padding: 0.2rem 0;
    }
    .chart-legend-left {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        min-width: 0;
    }
    .chart-legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex: 0 0 10px;
    }
    .chart-legend-label {
        color: #495057;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .chart-legend-value {
        color: #212529;
        font-weight: 600;
        white-space: nowrap;
    }
    .fallback-rate-good { color: var(--bs-success); }
    .fallback-rate-mid { color: var(--bs-warning); }
    .fallback-rate-bad { color: var(--bs-danger); }
</style>

<div class="container-fluid px-4">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    <!-- Auto-Advancement Switch -->
    <div class="card mb-4" style="background:#f8f9fa;border:2px solid #343a40;border-radius:12px;">
        <div class="card-body py-3">
            <form method="post" asp-page-handler="ToggleAutoAdvancement" id="autoAdvForm">
                <div class="form-check form-switch d-flex align-items-center">
                    <input class="form-check-input me-3" type="checkbox" role="switch" 
                           id="enableAutoAdv" name="enabled" value="true" 
                           @(Model.EnableAutoAdvancement ? "checked" : "")
                           onchange="this.form.submit();" 
                           style="width:3em;height:1.5em;cursor:pointer;">
                    <label class="form-check-label mb-0" for="enableAutoAdv" style="cursor:pointer;">
                        <strong>Avanzamento Automatico Storie</strong>
                        <div class="text-muted small mt-1">
                            Dopo 10 minuti di inattività del sistema (escludendo attività di embedding e summary),
                            viene eseguita la modalità selezionata.
                        </div>
                    </label>
                </div>
                <div class="mt-3">
                    <label for="autoAdvMode" class="form-label mb-1"><strong>Modalità avanzamento automatico</strong></label>
                    <select id="autoAdvMode" name="mode" class="form-select form-select-sm" style="max-width: 380px;" onchange="this.form.submit();">
                        @if (Model.AutoAdvancementMode == "series")
                        {
                            <option value="series" selected>Avanza serie (state-driven)</option>
                        }
                        else
                        {
                            <option value="series">Avanza serie (state-driven)</option>
                        }

                        @if (Model.AutoAdvancementMode == "nre")
                        {
                            <option value="nre" selected>Genera nuova storia NRE casuale (15 step)</option>
                        }
                        else
                        {
                            <option value="nre">Genera nuova storia NRE casuale (15 step)</option>
                        }

                        @if (Model.AutoAdvancementMode == "nre_manual")
                        {
                            <option value="nre_manual" selected>Genera nuova storia NRE manuale (fino a valutazione)</option>
                        }
                        else
                        {
                            <option value="nre_manual">Genera nuova storia NRE manuale (fino a valutazione)</option>
                        }

                        @if (Model.AutoAdvancementMode == "vatican_horror")
                        {
                            <option value="vatican_horror" selected>Genera nuova storia horror Vaticano (EN, 1a persona)</option>
                        }
                        else
                        {
                            <option value="vatican_horror">Genera nuova storia horror Vaticano (EN, 1a persona)</option>
                        }

                        @if (Model.AutoAdvancementMode == "complete_existing_first")
                        {
                            <option value="complete_existing_first" selected>Completa storie esistenti prima di crearne nuove</option>
                        }
                        else
                        {
                            <option value="complete_existing_first">Completa storie esistenti prima di crearne nuove</option>
                        }

                        @if (Model.AutoAdvancementMode == "complete_existing_then_vatican")
                        {
                            <option value="complete_existing_then_vatican" selected>Completa esistenti, poi genera solo storie Vaticano</option>
                        }
                        else
                        {
                            <option value="complete_existing_then_vatican">Completa esistenti, poi genera solo storie Vaticano</option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    <!-- Monomodel Mode -->
    <div class="card mb-4" style="background:#f8f9fa;border:2px solid #343a40;border-radius:12px;">
        <div class="card-body py-3">
            <form method="post" asp-page-handler="SetMonomodelMode" id="monomodelForm">
                <div class="form-check form-switch d-flex align-items-center">
                    <input class="form-check-input me-3" type="checkbox" role="switch"
                           id="enableMonomodelMode" name="enabled" value="true"
                           @(Model.MonomodelModeEnabled ? "checked" : "")
                           onchange="this.form.submit();"
                           style="width:3em;height:1.5em;cursor:pointer;">
                    <label class="form-check-label mb-0" for="enableMonomodelMode" style="cursor:pointer;">
                        <strong>Monomodel Mode</strong>
                        <div class="text-muted small mt-1">
                            Se attiva, il CallCenter forza tutti gli agenti sul modello selezionato
                            (escluso il modello usato per embedding).
                        </div>
                    </label>
                </div>
                <div class="mt-3">
                    <label for="monomodelDescription" class="form-label mb-1"><strong>Modello fisso (descrizione)</strong></label>
                    <select id="monomodelDescription" name="modelDescription" class="form-select form-select-sm" style="max-width: 420px;" onchange="this.form.submit();">
                        <option value="">-- seleziona modello --</option>
                        @foreach (var modelName in Model.AvailableModelDescriptions)
                        {
                            if (string.Equals(modelName, Model.MonomodelModelDescription, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@modelName" selected>@modelName</option>
                            }
                            else
                            {
                                <option value="@modelName">@modelName</option>
                            }
                        }
                    </select>
                </div>
            </form>
            <form method="post" asp-page-handler="SetCommandDispatcherParallelism" id="dispatcherParallelismForm" class="mt-3">
                <label for="maxParallelCommands" class="form-label mb-1"><strong>Processi agentici CommandDispatcher</strong></label>
                <input id="maxParallelCommands"
                       name="maxParallelCommands"
                       type="number"
                       class="form-control form-control-sm"
                       style="max-width: 220px;"
                       min="1"
                       max="64"
                       value="@Model.CommandDispatcherMaxParallelCommands"
                       onchange="this.form.submit();" />
                <div class="text-muted small mt-1">
                    Valore applicato subito al dispatcher e salvato in <code>appsettings.json</code>.
                </div>
            </form>
        </div>
    </div>

    @{
        var logRecordsKpi = Model.AdditionalKpis.FirstOrDefault(k =>
            string.Equals(k.Code, "KPI_32", StringComparison.OrdinalIgnoreCase));
        var additionalKpisWithoutLogCount = Model.AdditionalKpis
            .Where(k => !string.Equals(k.Code, "KPI_32", StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    <!-- KPI Cards Row -->
    <div class="row g-2 mb-2">
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-compact" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.GetKpiTooltip("KPI_01", "Storie Totali")">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-value">@Model.TotalStories</div>
                        <div class="kpi-label mt-1">Storie Totali</div>
                    </div>
                    <i class="bi bi-journal-text kpi-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-compact" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.GetKpiTooltip("KPI_02", "Modelli Attivi")">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-value">@Model.EnabledModels<span style="font-size: 1.2rem; opacity: 0.6;">/@(Model.EnabledModels + Model.DisabledModels)</span></div>
                        <div class="kpi-label mt-1">Modelli Attivi</div>
                    </div>
                    <i class="bi bi-cpu kpi-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-compact" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.GetKpiTooltip("KPI_08", "Modelli Disabilitati")">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-value">@Model.DisabledModels</div>
                        <div class="kpi-label mt-1">Modelli Disabilitati</div>
                    </div>
                    <i class="bi bi-pause-circle kpi-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-compact" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.GetKpiTooltip("KPI_18", "Audio Master Ready")">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-value">@Model.AudioMasterGeneratedCount</div>
                        <div class="kpi-label mt-1">Audio Master Ready</div>
                    </div>
                    <i class="bi bi-music-note-beamed kpi-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <div class="kpi-card kpi-compact kpi-brown-soft" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.GetKpiTooltip("KPI_DB_SIZE", "DB Size")">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-value">@Model.DatabaseSizeMb.ToString("F2")</div>
                        <div class="kpi-label mt-1">DB Size (MB)</div>
                    </div>
                    <i class="bi bi-database kpi-icon"></i>
                </div>
            </div>
        </div>
        @if (logRecordsKpi != null)
        {
            <div class="col-6 col-md-3 col-xl-2">
                <a class="kpi-link" href="@Url.Page("/Logs/Index")">
                    <div class="kpi-card kpi-compact kpi-brown-soft" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.GetKpiTooltip(logRecordsKpi.Code, logRecordsKpi.Label)">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="kpi-value">@logRecordsKpi.Value</div>
                                <div class="kpi-label mt-1">@logRecordsKpi.Label</div>
                                <small class="text-muted">@logRecordsKpi.Code</small>
                            </div>
                            <i class="bi bi-journal-richtext kpi-icon"></i>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
    @if (additionalKpisWithoutLogCount.Any())
    {
        <div class="row g-2 mb-4">
            @foreach (var kpi in additionalKpisWithoutLogCount)
            {
                <div class="col-6 col-md-3 col-xl-2">
                    <div class="kpi-card kpi-compact" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.GetKpiTooltip(kpi.Code, kpi.Label)">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="kpi-value">@kpi.Value</div>
                                <div class="kpi-label mt-1">@kpi.Label</div>
                                <small class="text-muted">@kpi.Code</small>
                            </div>
                            <i class="bi bi-graph-up-arrow kpi-icon"></i>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-6">
            <div class="chart-card">
                <div class="section-title mb-2">
                    <i class="bi bi-pie-chart me-2"></i>Storie per Stato (incluse soft deleted)
                </div>
                <div class="chart-wrap">
                    <canvas id="storiesByStatusChart"></canvas>
                </div>
                <ul class="chart-legend-list">
                    @if (Model.StoriesByStatusSlices.Any())
                    {
                        foreach (var slice in Model.StoriesByStatusSlices)
                        {
                            <li class="chart-legend-item">
                                <span class="chart-legend-left">
                                    <span class="chart-legend-dot" style="background:@slice.Color;"></span>
                                    <span class="chart-legend-label">@slice.Label</span>
                                </span>
                                <span class="chart-legend-value">@slice.Count (@slice.Percentage.ToString("F1")%)</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-muted small">Nessun dato disponibile.</li>
                    }
                </ul>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="chart-card">
                <div class="section-title mb-2">
                    <i class="bi bi-pie-chart-fill me-2"></i>Fasce Valutazione (storie ≥ 1000 caratteri, incluse soft deleted)
                </div>
                <div class="chart-wrap">
                    <canvas id="scoreBandsChart"></canvas>
                </div>
                <ul class="chart-legend-list">
                    @if (Model.ScoreBandSlices.Any())
                    {
                        foreach (var slice in Model.ScoreBandSlices)
                        {
                            <li class="chart-legend-item">
                                <span class="chart-legend-left">
                                    <span class="chart-legend-dot" style="background:@slice.Color;"></span>
                                    <span class="chart-legend-label">@slice.Label</span>
                                </span>
                                <span class="chart-legend-value">@slice.Count (@slice.Percentage.ToString("F1")%)</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-muted small">Nessun dato disponibile.</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Rankings Row -->
    <div class="row g-4">
        <!-- Top Writers -->
        <div class="col-lg-6">
            <div class="section-title">
                <i class="bi bi-trophy me-2"></i>Classifica Scrittori (per valutazione media)
            </div>
            <div class="ranking-table">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>Agente</th>
                            <th>Modello</th>
                            <th class="text-center">Storie</th>
                            <th class="text-end">Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.TopWriters.Any())
                        {
                            var rank = 0;
                            foreach (var writer in Model.TopWriters)
                            {
                                rank++;
                                var rankClass = rank switch { 1 => "rank-1", 2 => "rank-2", 3 => "rank-3", _ => "rank-other" };
                                <tr>
                                    <td><span class="rank-badge @rankClass">@rank</span></td>
                                    <td>@writer.AgentName</td>
                                    <td><small class="text-muted">@writer.ModelName</small></td>
                                    <td class="text-center">@writer.StoryCount</td>
                                    <td class="text-end"><span class="score-badge">@((writer.AvgScore * 100.0 / 40.0).ToString("F1"))</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-3">Nessun dato disponibile</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Top Stories -->
        <div class="col-lg-6">
            <div class="section-title">
                <i class="bi bi-star me-2"></i>Top 10 Storie (per valutazione)
            </div>
            <div class="ranking-table">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>Prompt</th>
                            <th>Modello</th>
                            <th class="text-end">Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.TopStories.Any())
                        {
                            var rank = 0;
                            foreach (var story in Model.TopStories)
                            {
                                rank++;
                                var rankClass = rank switch { 1 => "rank-1", 2 => "rank-2", 3 => "rank-3", _ => "rank-other" };
                                        <tr>
                                            <td><span class="rank-badge @rankClass">@rank</span></td>
                                            <td>
                                                @if (story.GeneratedMixedAudio)
                                                {
                                                    <button type="button" class="btn btn-sm btn-link p-0 me-2 play-final-mix-btn" data-story-id="@story.Id" data-story-title="@story.Title" title="Play final mix"><i class="bi bi-play-circle-fill" style="color:#0d6efd;font-size:1.25rem;"></i></button>
                                                }
                                                <a href="/Stories/Details/@story.Id" class="text-decoration-none" style="color: #9cf;">
                                                    @story.Title
                                                </a>
                                            </td>
                                            <td><small class="text-muted">@story.Agent</small></td>
                                            <td class="text-end"><span class="score-badge">@((story.AvgEvalScore * 100.0 / 40.0).ToString("F1")) /100</span></td>
                                        </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Nessun dato disponibile</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Best Models by Role -->
    <div class="mt-4">
        <div class="section-title">
            <i class="bi bi-award me-2"></i>Migliori Modelli per Ruolo
        </div>
        <div class="ranking-table">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Ruolo</th>
                        <th>Modello</th>
                        <th class="text-center">Utilizzi</th>
                        <th class="text-end">% Successo</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.BestModelsByRole.Any())
                    {
                        foreach (var row in Model.BestModelsByRole)
                        {
                            var hasResults = row.UseCount > 0;
                            var level = !hasResults
                                ? string.Empty
                                : (row.SuccessPct > 80.0 ? "good" : (row.SuccessPct >= 60.0 ? "mid" : "bad"));
                            var textClass = level == "good"
                                ? "fallback-rate-good"
                                : (level == "mid" ? "fallback-rate-mid" : (level == "bad" ? "fallback-rate-bad" : string.Empty));
                            <tr>
                                <td>@row.RoleName</td>
                                <td>@row.ModelName</td>
                                <td class="text-center">@row.UseCount</td>
                                <td class="text-end"><span class="@textClass">@row.SuccessPct.ToString("F1")%</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">Nessun dato disponibile</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent System Reports -->
    <div class="mt-4">
        <div class="section-title">
            <i class="bi bi-exclamation-octagon me-2"></i>Ultimi Report di Sistema
        </div>
        @if (Model.RecentReports.Any())
        {
            foreach (var report in Model.RecentReports)
            {
                var sevClass = (report.Severity ?? string.Empty).ToLowerInvariant() switch
                {
                    "critical" => "sev-critical",
                    "error" => "sev-error",
                    "warning" => "sev-warning",
                    _ => "sev-info"
                };
                <div class="report-card mb-3">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div class="flex-grow-1">
                            <div class="report-title">@report.Title</div>
                            <div class="report-meta">
                                @report.CreatedAt
                                @if (!string.IsNullOrWhiteSpace(report.OperationType))
                                {
                                    <span> • @report.OperationType</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(report.AgentName))
                                {
                                    <span> • @report.AgentName</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(report.ModelName))
                                {
                                    <span> • @report.ModelName</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(report.Message))
                            {
                                <div class="text-muted mt-2">@report.Message</div>
                            }
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <span class="report-badge @sevClass">@report.Severity</span>
                            <span class="report-badge">@report.Status</span>
                        </div>
                    </div>
                </div>
            }
            <div class="text-end d-flex justify-content-end gap-2">
                <a class="btn btn-sm btn-outline-secondary" asp-page="/SystemReports/Index">Vai ai report</a>
                <a class="btn btn-sm btn-outline-secondary" asp-page="/SystemReportsErrors/Index">Errori aggregati</a>
            </div>
        }
        else
        {
            <div class="text-muted">Nessun report disponibile.</div>
        }
    </div>
</div>

<!-- Modal per riprodurre final mix dalla home -->
<div class="modal fade" id="finalMixModal" tabindex="-1" aria-labelledby="finalMixModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" id="finalMixModalDialog">
        <div class="modal-content">
            <div class="modal-header" id="finalMixModalHeader" style="cursor: move;">
                <h5 class="modal-title" id="finalMixModalLabel">Riproduci Final Mix</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <div id="finalMixStoryTitle" class="fw-semibold mb-2"></div>
                <audio id="homeFinalMixAudio" controls preload="none" style="width:100%;">
                    Il tuo browser non supporta l'audio.
                </audio>
                <div id="finalMixInfo" class="mt-2 text-muted small"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Chiudi</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function(){
        var tooltipEls = Array.prototype.slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipEls.forEach(function (el) {
            if (!window.bootstrap || !window.bootstrap.Tooltip) return;
            window.bootstrap.Tooltip.getOrCreateInstance(el, {
                container: 'body',
                trigger: 'hover focus'
            });
        });

        var statusSlices = @Html.Raw(Model.StoriesByStatusJson);
        var scoreSlices = @Html.Raw(Model.ScoreBandJson);

        function ensureChartJs(ready){
            if (window.Chart) {
                ready();
                return;
            }
            var script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js';
            script.onload = ready;
            script.onerror = ready;
            document.head.appendChild(script);
        }

        function renderPie(canvasId, slices){
            if (!window.Chart) return;
            var canvas = document.getElementById(canvasId);
            if (!canvas || !Array.isArray(slices) || slices.length === 0) return;
            var normalized = slices
                .map(function(s){
                    return {
                        label: (s && (s.label ?? s.Label)) || '',
                        count: Number((s && (s.count ?? s.Count)) || 0),
                        color: (s && (s.color ?? s.Color)) || '#6c757d'
                    };
                })
                .filter(function(s){ return s.count > 0; });
            if (normalized.length === 0) return;
            var labels = normalized.map(function(s){ return s.label; });
            var values = normalized.map(function(s){ return s.count; });
            var colors = normalized.map(function(s){ return s.color; });
            new Chart(canvas, {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{ data: values, backgroundColor: colors, borderColor: '#f8f9fa', borderWidth: 2 }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }
                }
            });
        }

        ensureChartJs(function(){
            renderPie('storiesByStatusChart', statusSlices);
            renderPie('scoreBandsChart', scoreSlices);
        });

        document.addEventListener('click', function(e){
            var btn = e.target.closest && e.target.closest('.play-final-mix-btn');
            if (!btn) return;
            var storyId = btn.getAttribute('data-story-id');
            var storyTitle = btn.getAttribute('data-story-title') || ('Storia #' + storyId);
            if (!storyId) return;
            e.preventDefault();
            var audio = document.getElementById('homeFinalMixAudio');
            var info = document.getElementById('finalMixInfo');
            var titleEl = document.getElementById('finalMixStoryTitle');
            if (titleEl) titleEl.textContent = storyTitle;
            audio.pause();
            audio.src = '/Stories/Index?handler=FinalMixAudio&id=' + encodeURIComponent(storyId);
            audio.load();
            info.textContent = 'Caricamento...';
            var modalEl = document.getElementById('finalMixModal');
            var modal = new bootstrap.Modal(modalEl);
            modal.show();
            audio.onloadedmetadata = function(){
                info.textContent = 'Durata: ' + Math.floor((audio.duration||0)/60) + 'm ' + Math.round((audio.duration||0)%60) + 's';
                audio.play().catch(()=>{});
            };
            audio.onerror = function(){ info.textContent = 'Impossibile caricare l\'audio.'; };
            modalEl.addEventListener('hidden.bs.modal', function(){
                audio.pause();
                audio.removeAttribute('src');
                audio.load();
                info.textContent = '';
                if (titleEl) titleEl.textContent = '';
                var dialog = document.getElementById('finalMixModalDialog');
                if (dialog) {
                    dialog.style.margin = '';
                    dialog.style.position = '';
                    dialog.style.left = '';
                    dialog.style.top = '';
                    dialog.style.transform = '';
                }
            }, { once: true });
        });

        var dragState = null;
        var header = document.getElementById('finalMixModalHeader');
        var dialog = document.getElementById('finalMixModalDialog');
        if (header && dialog) {
            header.addEventListener('mousedown', function(evt){
                if (evt.button !== 0) return;
                var rect = dialog.getBoundingClientRect();
                dialog.style.margin = '0';
                dialog.style.position = 'fixed';
                dialog.style.left = rect.left + 'px';
                dialog.style.top = rect.top + 'px';
                dialog.style.transform = 'none';
                dragState = { dx: evt.clientX - rect.left, dy: evt.clientY - rect.top };
                evt.preventDefault();
            });
            document.addEventListener('mousemove', function(evt){
                if (!dragState) return;
                dialog.style.left = Math.max(0, evt.clientX - dragState.dx) + 'px';
                dialog.style.top = Math.max(0, evt.clientY - dragState.dy) + 'px';
            });
            document.addEventListener('mouseup', function(){ dragState = null; });
        }
    })();
</script>
