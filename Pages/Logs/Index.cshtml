@page
@model TinyGenerator.Pages.Logs.LogsModel
@{
    ViewData["Title"] = "Logs";
    ViewData["PageDescription"] = "Visualizza e gestisci i log dell'applicazione";
}

@section Styles {
    <link rel="stylesheet" href="~/js/vue-roles/roles-index.css" asp-append-version="true" />
    <style>
        /* Row coloring for model requests/responses */
        .log-model-request {
            background-color: #e9f7ec !important;
        }
        .log-model-request td {
            background-color: transparent !important;
        }
        .log-model-response {
            background-color: #fffbe6 !important;
        }
        .log-model-response td {
            background-color: transparent !important;
        }
        .log-response-checker {
            background-color: #fff9db !important;
        }
        .log-response-checker td {
            background-color: transparent !important;
        }
        .log-content-highlight {
            background: #ffe599;
            border-radius: 2px;
            padding: 0 2px;
            font-weight: 600;
        }
        .logs-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            align-items: center;
        }
        .logs-grid-card {
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #fff;
            padding: .375rem;
            overflow-x: auto;
        }
        .logs-datatable {
            min-width: 900px;
        }
        /* PrimeVue DataTable cursor pointer on rows */
        .logs-datatable .p-datatable-tbody > tr {
            cursor: pointer;
        }
    </style>
}

<div id="logs-vue-app"></div>

@section Scripts {
    <script type="module" src="~/js/logs/logs-index.js" asp-append-version="true"></script>
}
