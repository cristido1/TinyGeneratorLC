@page
@model TinyGenerator.Pages.ModelRoleErrors.IndexModel
@{
    ViewData["Title"] = "Model Role Errors";
    ViewData["PageDescription"] = "Errori per modello/ruolo dalla tabella model_roles_errors";

    string FormatDate(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return "-";
        }

        return DateTime.TryParse(raw, out var dt)
            ? dt.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss")
            : raw;
    }
}

@section Styles {
    <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/buttons.bootstrap5.min.css" />
}

<div class="page-wrapper">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info py-2 px-3 mb-2" role="alert">
            @Model.StatusMessage
        </div>
    }

    <style>
        .btn-group-vertical > .btn,
        .btn-group > .btn {
            flex: none;
        }

        .table-container {
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            padding: 1rem;
            background: #fff;
        }

        .filters-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
        }

        #modelRoleErrorsTable {
            font-size: 0.9rem;
            margin-bottom: 0;
        }
    </style>

    <form method="get" class="filters-row">
        <select class="form-select form-select-sm" name="ModelFilter" style="max-width: 340px;">
            <option value="">Tutti i modelli</option>
            @foreach (var modelName in Model.AvailableModels)
            {
                if (string.Equals(Model.ModelFilter, modelName, StringComparison.OrdinalIgnoreCase))
                {
                    <option value="@modelName" selected>@modelName</option>
                }
                else
                {
                    <option value="@modelName">@modelName</option>
                }
            }
        </select>

        <select class="form-select form-select-sm" name="RoleFilter" style="max-width: 260px;">
            <option value="">Tutti i ruoli</option>
            @foreach (var roleCode in Model.AvailableRoles)
            {
                if (string.Equals(Model.RoleFilter, roleCode, StringComparison.OrdinalIgnoreCase))
                {
                    <option value="@roleCode" selected>@roleCode</option>
                }
                else
                {
                    <option value="@roleCode">@roleCode</option>
                }
            }
        </select>

        <button type="submit" class="btn btn-sm btn-light border">
            <i class="bi bi-funnel me-1"></i>Applica filtri
        </button>
        <a class="btn btn-sm btn-light border" asp-page="./Index">
            <i class="bi bi-x-circle me-1"></i>Reset
        </a>
    </form>

    <div class="table-container">
        <table class="table table-hover" id="modelRoleErrorsTable">
            <thead class="table-light">
                <tr>
                    <th data-col="model">Nome Modello</th>
                    <th data-col="operation">Operazione</th>
                    <th data-col="role">Ruolo</th>
                    <th data-col="id">id</th>
                    <th data-col="parentId">parent_id</th>
                    <th data-col="errorText">error_text</th>
                    <th data-col="errorType">error_type</th>
                    <th data-col="errorCount">error_count</th>
                    <th data-col="dateInsert">date_insert</th>
                    <th data-col="dateLast">date_last</th>
                    <th data-col="actions">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Items)
                {
                    <tr>
                        <td data-col="model">@row.ModelName</td>
                        <td data-col="operation">@(string.IsNullOrWhiteSpace(row.Operation) ? "-" : row.Operation)</td>
                        <td data-col="role">@row.RoleCode</td>
                        <td data-col="id">@row.Id</td>
                        <td data-col="parentId">@row.ParentId</td>
                        <td data-col="errorText" style="white-space: pre-wrap;">@row.ErrorText</td>
                        <td data-col="errorType">@row.ErrorType</td>
                        <td data-col="errorCount">@row.ErrorCount</td>
                        <td data-col="dateInsert">@FormatDate(row.DateInsert)</td>
                        <td data-col="dateLast">@FormatDate(row.DateLast)</td>
                        <td data-col="actions">
                            <form method="post" asp-page-handler="Delete" class="m-0" onsubmit="return confirm('Confermi eliminazione record @row.Id?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@row.Id" />
                                <input type="hidden" name="modelFilter" value="@Model.ModelFilter" />
                                <input type="hidden" name="roleFilter" value="@Model.RoleFilter" />
                                <button type="submit" class="btn btn-sm btn-light border text-danger">
                                    <i class="bi bi-trash me-1"></i>Elimina
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    (function initModelRoleErrorsTable() {
        if (typeof jQuery === 'undefined') { setTimeout(initModelRoleErrorsTable, 50); return; }
        var scripts = [
            '/lib/datatables/js/jquery.dataTables.min.js',
            '/lib/datatables/js/dataTables.bootstrap5.min.js',
            '/lib/datatables/js/dataTables.buttons.min.js',
            '/lib/datatables/js/buttons.bootstrap5.min.js',
            '/lib/datatables/js/buttons.colVis.min.js'
        ];
        var i = 0;
        function load(url, cb) {
            var s = document.createElement('script');
            s.src = url;
            s.onload = cb;
            s.onerror = function () { console.error('Failed to load script:', url); cb(); };
            document.head.appendChild(s);
        }
        function next() {
            if (i < scripts.length) load(scripts[i++], next);
            else init();
        }
        next();

        function init() {
            jQuery(function ($) {
                if (typeof $.fn.DataTable === 'undefined') {
                    console.error('DataTables not loaded');
                    return;
                }

                if ($.fn.DataTable.isDataTable('#modelRoleErrorsTable')) {
                    try { $('#modelRoleErrorsTable').DataTable().destroy(); } catch (e) { }
                }

                $('#modelRoleErrorsTable').DataTable({
                    dom: "<'row mb-2'<'col-sm-6'B><'col-sm-6 text-end'f>>" +
                         "rt" +
                         "<'row mt-2'<'col-sm-6'i><'col-sm-6 text-end'p>>",
                    stateSave: true,
                    paging: true,
                    pageLength: 25,
                    lengthChange: true,
                    lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                    order: [[7, 'desc'], [9, 'desc']],
                    buttons: [
                        {
                            text: '<i class="bi bi-arrow-clockwise me-1"></i>Aggiorna',
                            className: 'btn btn-sm btn-light border me-1',
                            attr: { style: 'width: auto; flex: 0 0 auto;' },
                            action: function () { location.reload(); }
                        },
                        {
                            extend: 'colvis',
                            text: 'Colonne',
                            className: 'btn btn-sm btn-light border',
                            attr: { style: 'width: auto; flex: 0 0 auto;' }
                        }
                    ]
                });
            });
        }
    })();
</script>
