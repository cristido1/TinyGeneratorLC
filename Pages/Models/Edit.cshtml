@page
@model TinyGenerator.Pages.Models.EditModel
@{
    ViewData["Title"] = "Edit Model";
}

<h3>@(string.IsNullOrEmpty(Model.Model?.Name) ? "Create model" : "Edit model: " + Model.Model.Name)</h3>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Model.Id" />

    <div class="mb-3">
        <label class="form-label">Nome</label>
        <input asp-for="Model.Name" class="form-control" />
        <span asp-validation-for="Model.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">CallName (nome reale richiesta)</label>
        <input asp-for="Model.CallName" class="form-control" placeholder="es. qwen3:14b" />
        <span asp-validation-for="Model.CallName" class="text-danger"></span>
        <small class="form-text text-muted">Se vuoto, viene usato automaticamente Name.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Size testo</label>
        <input asp-for="Model.SizeText" class="form-control" placeholder="es. 7B, 30B, 35B-A3B" />
        <span asp-validation-for="Model.SizeText" class="text-danger"></span>
        <small class="form-text text-muted">Se vuoto, viene dedotto automaticamente dal nome modello.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Provider</label>
        <select asp-for="Model.Provider" class="form-select">
            <option value="ollama">ollama</option>
            <option value="llama.cpp">llama.cpp</option>
            <option value="openai">openai</option>
        </select>
        <span asp-validation-for="Model.Provider" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Image (path relativo in wwwroot)</label>
        <input asp-for="Model.Image" class="form-control" placeholder="providers/openai.svg" />
        <span asp-validation-for="Model.Image" class="text-danger"></span>
        <small class="form-text text-muted">Esempio: <code>providers/qwen.svg</code></small>
    </div>

    <div class="mb-3">
        <label class="form-label">Endpoint</label>
        <input asp-for="Model.Endpoint" class="form-control" placeholder="http://localhost:11434 or http://localhost:1234 (leave empty for default)" />
        <span asp-validation-for="Model.Endpoint" class="text-danger"></span>
        <small class="form-text text-muted">Custom API endpoint URL (optional)</small>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">MaxContext</label>
            <input asp-for="Model.MaxContext" class="form-control" />
            <span asp-validation-for="Model.MaxContext" class="text-danger"></span>
        </div>
        <div class="col-md-8 mb-3">
            <label class="form-label">ContextToUse</label>
            <input asp-for="Model.ContextToUse" class="form-control" />
            <span asp-validation-for="Model.ContextToUse" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">CostInPerToken (dollars per token)</label>
            <input asp-for="Model.CostInPerToken" class="form-control" />
            <span asp-validation-for="Model.CostInPerToken" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">CostOutPerToken (dollars per token)</label>
            <input asp-for="Model.CostOutPerToken" class="form-control" />
            <span asp-validation-for="Model.CostOutPerToken" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">LimitTokensDay</label>
            <input asp-for="Model.LimitTokensDay" class="form-control" />
            <span asp-validation-for="Model.LimitTokensDay" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">LimitTokensWeek</label>
            <input asp-for="Model.LimitTokensWeek" class="form-control" />
            <span asp-validation-for="Model.LimitTokensWeek" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">LimitTokensMonth</label>
            <input asp-for="Model.LimitTokensMonth" class="form-control" />
            <span asp-validation-for="Model.LimitTokensMonth" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Model.Enabled" class="form-check-input" />
        <label class="form-check-label">Enabled</label>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Model.NoTools" class="form-check-input" />
        <label class="form-check-label">NoTools</label>
        <small class="form-text text-muted d-block">Check if model does not support function calling/tools</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Thinking (fallback)</label>
        <select asp-for="Model.Thinking" class="form-select">
            <option value="">null (non forzare)</option>
            <option value="true">true</option>
            <option value="false">false</option>
        </select>
        <small class="form-text text-muted">Usato quando l'agente non ha un valore Thinking esplicito.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Note</label>
        <textarea asp-for="Model.Note" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Model.Note" class="text-danger"></span>
        <small class="form-text text-muted">Free-form note or comment for this model.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Sort Order</label>
        <input asp-for="Model.SortOrder" class="form-control" type="number" step="10" />
        <span asp-validation-for="Model.SortOrder" class="text-danger"></span>
        <small class="form-text text-muted">Usato per l'ordinamento quando l'entità implementa IOrderable.</small>
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-secondary ms-2" asp-page="Index">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
