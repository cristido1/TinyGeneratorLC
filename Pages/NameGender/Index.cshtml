@page
@model TinyGenerator.Pages.NameGender.IndexModel
@{
    ViewData["Title"] = "Name Gender";
    ViewData["PageDescription"] = "Mappa nomi -> gender usata dalla normalizzazione personaggi";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/buttons.bootstrap5.min.css" />
    <style>
        .btn-group-vertical > .btn, .btn-group > .btn { flex: none; }
        #nameGenderTable { font-size: 0.92rem; }
        #nameGenderTable thead th {
            font-weight: 600;
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: .4px;
        }
        .gender-pill {
            display: inline-block;
            min-width: 80px;
            text-align: center;
            padding: .15rem .45rem;
            border-radius: 999px;
            font-weight: 600;
            border: 1px solid #dee2e6;
            background: #f8f9fa;
        }
        .gender-male { color: #0d6efd; }
        .gender-female { color: #d63384; }
        .gender-robot { color: #198754; }
        .gender-alien { color: #fd7e14; }
        .gender-unknown { color: #6c757d; }
        .name-unverified { opacity: .78; }
        .table-container {
            border: 1px solid #dee2e6;
            border-radius: .375rem;
            padding: 1rem;
            background: white;
        }
    </style>
}

<div class="container-fluid py-3">
    @if (!string.IsNullOrWhiteSpace(Model.LoadError))
    {
        <div class="alert alert-danger py-2">@Model.LoadError</div>
    }

    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-sm-5 col-md-4 col-lg-3">
            <label class="form-label mb-1" for="searchTop">Cerca nome</label>
            <input id="searchTop" type="text" name="search" value="@Model.Search" class="form-control form-control-sm" />
        </div>
        <div class="col-sm-auto">
            <button type="submit" class="btn btn-sm btn-primary">Filtra</button>
        </div>
        <div class="col-sm-auto">
            <a href="/NameGender/Index" class="btn btn-sm btn-outline-secondary">Reset</a>
        </div>
    </form>

    <form id="nameGenderAntiForgeryForm" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="table-container">
        <table id="nameGenderTable" class="table table-hover align-middle">
            <thead>
                <tr>
                    <th data-col="actions">Azioni</th>
                    <th data-col="id">Id</th>
                    <th data-col="name">Name</th>
                    <th data-col="gender">Gender</th>
                    <th data-col="verified">Verified</th>
                    <th data-col="insertDate">Insert Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var genderCss = $"gender-pill gender-{(string.IsNullOrWhiteSpace(item.Gender) ? "unknown" : item.Gender.Trim().ToLowerInvariant())}";
                    var insertDateDisplay = DateTime.TryParse(item.InsertDate, out var parsedInsertDate)
                        ? parsedInsertDate.ToString("dd/MM/yyyy HH:mm")
                        : item.InsertDate;
                    <tr data-item-id="@item.Id" class="@(item.Verified ? string.Empty : "name-unverified")">
                        <td data-col="actions">
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-sm btn-light border js-cycle-gender">Change gender</button>
                                <button type="button" class="btn btn-sm btn-light border text-danger js-delete-row">Delete</button>
                            </div>
                        </td>
                        <td data-col="id">@item.Id</td>
                        <td data-col="name"><strong>@item.Name</strong></td>
                        <td data-col="gender">
                            <span class="@genderCss js-gender-text">@item.Gender</span>
                        </td>
                        <td data-col="verified">
                            <div class="form-check m-0">
                                <input class="form-check-input js-verified-toggle" type="checkbox" @(item.Verified ? "checked" : null) />
                            </div>
                        </td>
                        <td data-col="insertDate">@insertDateDisplay</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
(function initNameGenderTable() {
    if (typeof jQuery === 'undefined') {
        setTimeout(initNameGenderTable, 50);
        return;
    }

    var scripts = [
        '/lib/datatables/js/jquery.dataTables.min.js',
        '/lib/datatables/js/dataTables.bootstrap5.min.js',
        '/lib/datatables/js/dataTables.buttons.min.js',
        '/lib/datatables/js/buttons.bootstrap5.min.js',
        '/lib/datatables/js/buttons.colVis.min.js'
    ];

    var idx = 0;
    function loadScript(url, callback) {
        var s = document.createElement('script');
        s.src = url;
        s.onload = callback;
        s.onerror = callback;
        document.head.appendChild(s);
    }
    function next() {
        if (idx < scripts.length) {
            loadScript(scripts[idx++], next);
            return;
        }
        initTableAndActions();
    }
    next();

    function initTableAndActions() {
        jQuery(function($) {
            var table = $('#nameGenderTable').DataTable({
                dom: "<'row mb-2'<'col-sm-6'B><'col-sm-6 text-end'f>>" +
                     "rt" +
                     "<'row mt-2'<'col-sm-6'i><'col-sm-6 text-end'p>>",
                stateSave: true,
                pageLength: 25,
                lengthMenu: [[10,25,50,100],[10,25,50,100]],
                order: [[2, 'asc']],
                columnDefs: [
                    { orderable: false, targets: [0, 4] }
                ],
                buttons: [
                    {
                        extend: 'colvis',
                        text: '<i class="bi bi-layout-three-columns me-1"></i>Colonne',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' }
                    },
                    {
                        text: '<i class="bi bi-arrow-clockwise me-1"></i>Refresh',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() { location.reload(); }
                    }
                ]
            });

            var tokenInput = document.querySelector('#nameGenderAntiForgeryForm input[name="__RequestVerificationToken"]');
            var antiForgeryToken = tokenInput ? tokenInput.value : '';

            function postHandler(handler, data) {
                var body = new URLSearchParams(data);
                return fetch('/NameGender/Index?handler=' + encodeURIComponent(handler), {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'RequestVerificationToken': antiForgeryToken
                    },
                    body: body.toString()
                }).then(function(r) {
                    return r.json().then(function(j) { return { ok: r.ok, json: j }; });
                });
            }

            function setGenderBadge(el, gender) {
                if (!el) return;
                var g = (gender || 'unknown').toLowerCase();
                el.textContent = g;
                el.className = 'gender-pill js-gender-text gender-' + g;
            }

            document.addEventListener('change', function(ev) {
                var cb = ev.target && ev.target.closest ? ev.target.closest('.js-verified-toggle') : null;
                if (!cb) return;
                var row = cb.closest('tr[data-item-id]');
                if (!row) return;
                var id = row.getAttribute('data-item-id');
                if (!id) return;
                var checked = cb.checked;
                postHandler('ToggleVerified', { id: id, verified: checked ? 'true' : 'false' })
                    .then(function(res) {
                        if (!res.ok || !res.json || !res.json.ok) {
                            cb.checked = !checked;
                            alert((res.json && res.json.error) || 'Errore salvataggio verified');
                            return;
                        }
                        row.classList.toggle('name-unverified', !checked);
                    })
                    .catch(function() {
                        cb.checked = !checked;
                        alert('Errore di rete durante il salvataggio verified');
                    });
            });

            document.addEventListener('click', function(ev) {
                var cycleBtn = ev.target && ev.target.closest ? ev.target.closest('.js-cycle-gender') : null;
                if (cycleBtn) {
                    var cycleRow = cycleBtn.closest('tr[data-item-id]');
                    if (!cycleRow) return;
                    var cycleId = cycleRow.getAttribute('data-item-id');
                    cycleBtn.disabled = true;
                    postHandler('CycleGender', { id: cycleId })
                        .then(function(res) {
                            if (!res.ok || !res.json || !res.json.ok) {
                                alert((res.json && res.json.error) || 'Errore cambio gender');
                                return;
                            }
                            setGenderBadge(cycleRow.querySelector('.js-gender-text'), res.json.gender || 'unknown');
                        })
                        .catch(function() {
                            alert('Errore di rete durante il cambio gender');
                        })
                        .finally(function() {
                            cycleBtn.disabled = false;
                        });
                    return;
                }

                var delBtn = ev.target && ev.target.closest ? ev.target.closest('.js-delete-row') : null;
                if (!delBtn) return;
                var delRow = delBtn.closest('tr[data-item-id]');
                if (!delRow) return;
                var delId = delRow.getAttribute('data-item-id');
                if (!confirm('Eliminare questo record name_gender?')) return;
                delBtn.disabled = true;
                postHandler('DeleteRow', { id: delId })
                    .then(function(res) {
                        if (!res.ok || !res.json || !res.json.ok) {
                            alert((res.json && res.json.error) || 'Errore delete');
                            return;
                        }
                        table.row($(delRow)).remove().draw(false);
                    })
                    .catch(function() {
                        alert('Errore di rete durante la delete');
                    })
                    .finally(function() {
                        delBtn.disabled = false;
                    });
            });
        });
    }
})();
</script>
