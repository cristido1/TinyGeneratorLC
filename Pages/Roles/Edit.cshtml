@page
@model TinyGenerator.Pages.Roles.EditModel
@{
    var isNew = Model.Role.Id == 0;
    ViewData["Title"] = isNew ? "Nuovo Ruolo" : "Modifica Ruolo";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center gap-2 py-3">
                <i class="bi bi-person-gear fs-5 text-primary"></i>
                <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>
                @if (!isNew)
                {
                    <span class="badge bg-secondary ms-auto">#@Model.Role.Id</span>
                }
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Role.Id" />

                    <div class="mb-4">
                        <label asp-for="Role.Name" class="form-label fw-semibold">
                            <i class="bi bi-tag me-1 text-muted"></i>Ruolo
                        </label>
                        <input asp-for="Role.Name" class="form-control" required placeholder="Es: assistant, planner, summarizer…" />
                        <span asp-validation-for="Role.Name" class="text-danger small"></span>
                        <div class="form-text">Nome identificativo del ruolo nel sistema.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Role.LinkedCommand" class="form-label fw-semibold">
                            <i class="bi bi-link-45deg me-1 text-muted"></i>Comando Collegato
                        </label>
                        <input asp-for="Role.LinkedCommand" class="form-control font-monospace"
                               placeholder="Es: AddVoiceTagsToStoryCommand" />
                        <span asp-validation-for="Role.LinkedCommand" class="text-danger small"></span>
                        <div class="form-text">Nome del comando o operazione associata a questo ruolo (opzionale).</div>
                    </div>

                    <hr class="my-3" />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i>Salva
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Annulla
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
