@page
@model TinyGenerator.Pages.Sounds.EditModel
@{
    ViewData["Title"] = "Modifica Suono";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Modifica Suono #@Model.Sound.Id</h2>
        <a class="btn btn-outline-secondary" href="/Sounds/Index">Torna alla lista</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                <input asp-for="Sound.Id" type="hidden" />
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Sound.Type" class="form-label"></label>
                        <select asp-for="Sound.Type" class="form-select">
                            @foreach (var t in Model.AllowedTypes)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-9">
                        <label asp-for="Sound.Library" class="form-label"></label>
                        <input asp-for="Sound.Library" class="form-control" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Sound.FilePath" class="form-label"></label>
                        <input asp-for="Sound.FilePath" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Sound.FileName" class="form-label"></label>
                        <input asp-for="Sound.FileName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Sound.Tags" class="form-label"></label>
                        <input asp-for="Sound.Tags" class="form-control" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Sound.Description" class="form-label"></label>
                        <textarea asp-for="Sound.Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="col-12">
                        <label asp-for="Sound.Embedding" class="form-label"></label>
                        <textarea asp-for="Sound.Embedding" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Durata (s)</label>
                        <input class="form-control" value="@Model.Sound.DurationSeconds?.ToString("0.###")" readonly />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Sound.ScoreHuman" class="form-label"></label>
                        <input asp-for="Sound.ScoreHuman" type="number" step="0.01" min="0" max="100" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Score Final</label>
                        <input class="form-control" value="@Model.Sound.ScoreFinal?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Score Last Calc</label>
                        <input class="form-control" value="@Model.Sound.ScoreLastCalc" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Score Version</label>
                        <input class="form-control" value="@Model.Sound.ScoreVersion" readonly />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Loudness</label>
                        <input class="form-control" value="@Model.Sound.ScoreLoudness?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Dynamic</label>
                        <input class="form-control" value="@Model.Sound.ScoreDynamic?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Clipping</label>
                        <input class="form-control" value="@Model.Sound.ScoreClipping?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Noise</label>
                        <input class="form-control" value="@Model.Sound.ScoreNoise?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Duration</label>
                        <input class="form-control" value="@Model.Sound.ScoreDuration?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Format</label>
                        <input class="form-control" value="@Model.Sound.ScoreFormat?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Consistency</label>
                        <input class="form-control" value="@Model.Sound.ScoreConsistency?.ToString("0.##")" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Tag Match</label>
                        <input class="form-control" value="@Model.Sound.ScoreTagMatch?.ToString("0.##")" readonly />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Usage Count</label>
                        <input class="form-control" value="@Model.Sound.UsageCount" readonly />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Usage Last</label>
                        <input class="form-control" value="@Model.Sound.UsageLast" readonly />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Anteprima</label>
                        <audio controls preload="none" style="width:100%;" src="/Sounds/Index?handler=Audio&id=@Model.Sound.Id"></audio>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Salva</button>
                    <a class="btn btn-outline-secondary" href="/Sounds/Index">Annulla</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
