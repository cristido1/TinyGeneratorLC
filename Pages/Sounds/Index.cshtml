@page
@model TinyGenerator.Pages.Sounds.IndexModel
@{
    ViewData["Title"] = "Sounds";
    ViewData["PageDescription"] = "Libreria suoni WAV/MP3 (fx/music/amb)";
    var jsTypeFilter = Model.TypeFilter ?? string.Empty;

    string ScoreCss(double? value)
    {
        if (!value.HasValue) return "score-empty";
        if (value.Value < 50) return "score-low";
        if (value.Value < 75) return "score-mid";
        return "score-high";
    }

    string FormatInsertDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        return DateTime.TryParse(value, out var dt)
            ? dt.ToString("yyyy/MM/dd HH:mm")
            : value;
    }
}

@section Styles {
    <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/buttons.bootstrap5.min.css" />
    <style>
        .btn-group-vertical > .btn, .btn-group > .btn { flex: none; }
        .sound-player { width: 220px; max-width: 100%; }
        .sound-path { max-width: 460px; word-break: break-all; }
        .score-pill {
            display: inline-block;
            min-width: 58px;
            text-align: center;
            padding: 0.15rem 0.4rem;
            border-radius: 999px;
            font-weight: 600;
            line-height: 1.2;
        }
        .score-low { background: #f8d7da; color: #842029; }
        .score-mid { background: #fff3cd; color: #664d03; }
        .score-high { background: #d1e7dd; color: #0f5132; }
        .score-empty { color: #6c757d; }
        .sound-disabled-row { opacity: 0.55; color: #6c757d; }
        .sound-disabled-row a,
        .sound-disabled-row .badge,
        .sound-disabled-row .btn { opacity: 0.9; }
    </style>
}

<div class="container-fluid py-3">
    @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success py-2">@ok</div>
    }
    @if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-danger py-2">@err</div>
    }

    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-sm-4 col-md-3 col-lg-2">
            <label for="typeFilterTop" class="form-label mb-1">Tipo</label>
            <select id="typeFilterTop" name="typeFilter" class="form-select form-select-sm">
                <option value="" selected="@(string.IsNullOrWhiteSpace(Model.TypeFilter))">Tutti</option>
                <option value="fx" selected="@(string.Equals(Model.TypeFilter, "fx", StringComparison.OrdinalIgnoreCase))">fx</option>
                <option value="music" selected="@(string.Equals(Model.TypeFilter, "music", StringComparison.OrdinalIgnoreCase))">music</option>
                <option value="amb" selected="@(string.Equals(Model.TypeFilter, "amb", StringComparison.OrdinalIgnoreCase))">amb</option>
            </select>
        </div>
        <div class="col-sm-auto">
            <button type="submit" class="btn btn-sm btn-primary">Filtra</button>
        </div>
        <div class="col-sm-auto">
            <a href="/Sounds/Index?typeFilter=" class="btn btn-sm btn-outline-secondary">Reset</a>
        </div>
    </form>

    <div class="d-flex gap-2 mb-2">
        <form method="post" asp-page-handler="EnqueueRecalculateScores" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
            <button type="submit" class="btn btn-sm btn-outline-primary">Ricalcola score (tutti)</button>
        </form>
        <form id="enqueueMissingScoresForm" method="post" asp-page-handler="EnqueueRecalculateMissingScores" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
            <button type="submit" class="btn btn-sm btn-outline-secondary">Accoda score mancanti</button>
        </form>
        <form id="enqueueMissingDurationsForm" method="post" asp-page-handler="EnqueueBackfillMissingDurations" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
            <button type="submit" class="btn btn-sm btn-outline-secondary">Calcola durate mancanti</button>
        </form>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table id="soundsTable" class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th data-col="actions">Azioni</th>
                        <th data-col="listen">Ascolta</th>
                        <th data-col="id">Id</th>
                        <th data-col="type">Type</th>
                        <th data-col="library">Library</th>
                        <th data-col="soundname">SoundName</th>
                        <th data-col="description">Description</th>
                        <th data-col="tags">Tags</th>
                        <th data-col="usageCount">Usage Count</th>
                        <th data-col="usageLast">Usage Last</th>
                        <th data-col="insertDate">Inserito il</th>
                        <th data-col="durationSeconds">Durata (s)</th>
                        <th data-col="scoreFinal">Score Final</th>
                        <th data-col="scoreHuman">Score Human</th>
                        <th data-col="scoreLoudness">Score Loudness</th>
                        <th data-col="scoreDynamic">Score Dynamic</th>
                        <th data-col="scoreClipping">Score Clipping</th>
                        <th data-col="scoreNoise">Score Noise</th>
                        <th data-col="scoreDuration">Score Duration</th>
                        <th data-col="scoreFormat">Score Format</th>
                        <th data-col="scoreConsistency">Score Consistency</th>
                        <th data-col="scoreTagMatch">Score Tag Match</th>
                        <th data-col="scoreLastCalc">Score Last Calc</th>
                        <th data-col="scoreVersion">Score Version</th>
                        <th data-col="soundpath">SoundPath</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
(function initSoundsTable() {
    if (typeof jQuery === 'undefined') {
        setTimeout(initSoundsTable, 50);
        return;
    }

    var scripts = [
        '/lib/datatables/js/jquery.dataTables.min.js',
        '/lib/datatables/js/dataTables.bootstrap5.min.js',
        '/lib/datatables/js/dataTables.buttons.min.js',
        '/lib/datatables/js/buttons.bootstrap5.min.js',
        '/lib/datatables/js/buttons.colVis.min.js'
    ];

    var idx = 0;
    function loadScript(url, callback) {
        var s = document.createElement('script');
        s.src = url;
        s.onload = callback;
        s.onerror = callback;
        document.head.appendChild(s);
    }
    function next() {
        if (idx < scripts.length) {
            loadScript(scripts[idx++], next);
            return;
        }
        initializeDataTable();
    }
    next();

    function initializeDataTable() {
        jQuery(function($) {
            if (typeof $.fn.DataTable === 'undefined') return;
            const currentTypeFilter = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(jsTypeFilter));
            const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            function esc(v) {
                if (v === null || v === undefined) return '';
                return String(v)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function fmtNum(v, digits) {
                if (v === null || v === undefined || v === '') return '';
                const n = Number(v);
                return Number.isFinite(n) ? n.toFixed(digits).replace(/\.00$/, '').replace(/(\.\d)0$/, '$1') : esc(v);
            }

            function scoreCss(v) {
                if (v === null || v === undefined || v === '') return 'score-empty';
                const n = Number(v);
                if (!Number.isFinite(n)) return 'score-empty';
                if (n < 50) return 'score-low';
                if (n < 75) return 'score-mid';
                return 'score-high';
            }

            function fmtInsertDate(v) {
                if (!v) return '';
                const d = new Date(v);
                if (Number.isNaN(d.getTime())) return esc(v);
                const yyyy = d.getFullYear();
                const MM = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                const HH = String(d.getHours()).padStart(2, '0');
                const mm = String(d.getMinutes()).padStart(2, '0');
                return `${yyyy}/${MM}/${dd} ${HH}:${mm}`;
            }

            function typeBadge(type, enabled) {
                const t = (type || '').toLowerCase();
                const cls = t === 'amb' ? 'bg-success' : (t === 'music' ? 'bg-primary' : 'bg-secondary');
                let html = `<span class="badge ${cls}">${esc(type || '')}</span>`;
                if (!enabled) {
                    html += ' <span class="badge bg-light text-muted border ms-1">disabled</span>';
                }
                return html;
            }

            function rowActions(row) {
                const id = Number(row.id ?? row.Id);
                const typeFilterHidden = `<input type="hidden" name="typeFilter" value="${esc(currentTypeFilter)}" />`;
                const tokenInput = antiForgeryToken ? `<input type="hidden" name="__RequestVerificationToken" value="${esc(antiForgeryToken)}" />` : '';
                return `
<div class="dropdown">
  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Azioni</button>
  <ul class="dropdown-menu dropdown-menu-end">
    <li>
      <form method="post" action="/Sounds/Index?handler=EnqueueRecalculateRowScore" class="m-0">
        ${tokenInput}
        <input type="hidden" name="id" value="${id}" />
        ${typeFilterHidden}
        <button type="submit" class="dropdown-item">Accoda ricalcolo score</button>
      </form>
    </li>
    <li><a class="dropdown-item" href="/Sounds/Edit?id=${id}">Edit</a></li>
    <li><hr class="dropdown-divider" /></li>
    <li>
      <form method="post" action="/Sounds/Index?handler=Delete" class="m-0" onsubmit="return confirm('Eliminare questo suono?');">
        ${tokenInput}
        <input type="hidden" name="id" value="${id}" />
        ${typeFilterHidden}
        <button type="submit" class="dropdown-item text-danger">Delete</button>
      </form>
    </li>
  </ul>
</div>`;
            }

            $('#soundsTable').DataTable({
                dom: "<'row mb-2'<'col-sm-6'B><'col-sm-6 text-end'f>>" +
                     "rt" +
                     "<'row mt-2'<'col-sm-6'i><'col-sm-6 text-end'p>>",
                stateSave: true,
                stateDuration: 0, // localStorage persistente sul dispositivo (standard DataTables)
                processing: true,
                serverSide: true,
                pageLength: 25,
                lengthMenu: [[10,25,50,100],[10,25,50,100]],
                ajax: {
                    url: '/api/sounds/datatable',
                    type: 'POST',
                    data: function(d) {
                        d.typeFilter = currentTypeFilter || '';
                    }
                },
                order: [[12, 'desc']],
                columns: [
                    { data: 'id', name: 'actions', render: function(_, __, row){ return rowActions(row); }, orderable: false },
                    { data: 'id', name: 'listen', render: function(v){ return `<audio class="sound-player" controls preload="none" src="/Sounds/Index?handler=Audio&id=${Number(v)}"></audio>`; }, orderable: false },
                    { data: 'id', name: 'id' },
                    { data: 'type', name: 'type', render: function(v, __, row){ return typeBadge(v, !!(row.enabled ?? row.Enabled)); } },
                    { data: 'library', name: 'library', defaultContent: '' },
                    { data: 'soundName', name: 'soundname', defaultContent: '' },
                    { data: 'description', name: 'description', defaultContent: '' },
                    { data: 'tags', name: 'tags', defaultContent: '' },
                    { data: 'usageCount', name: 'usageCount', defaultContent: 0 },
                    { data: 'usageLast', name: 'usageLast', defaultContent: '' },
                    { data: 'insertDate', name: 'insertDate', render: function(v){ return fmtInsertDate(v); } },
                    { data: 'durationSeconds', name: 'durationSeconds', render: function(v){ return fmtNum(v, 3); } },
                    { data: 'scoreFinal', name: 'scoreFinal', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreHuman', name: 'scoreHuman', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreLoudness', name: 'scoreLoudness', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreDynamic', name: 'scoreDynamic', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreClipping', name: 'scoreClipping', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreNoise', name: 'scoreNoise', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreDuration', name: 'scoreDuration', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreFormat', name: 'scoreFormat', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreConsistency', name: 'scoreConsistency', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreTagMatch', name: 'scoreTagMatch', render: function(v){ return `<span class="score-pill ${scoreCss(v)}">${fmtNum(v, 2)}</span>`; } },
                    { data: 'scoreLastCalc', name: 'scoreLastCalc', defaultContent: '' },
                    { data: 'scoreVersion', name: 'scoreVersion', defaultContent: '' },
                    { data: 'soundPath', name: 'soundpath', defaultContent: '', className: 'sound-path' }
                ],
                columnDefs: [
                    { orderable: false, targets: [0, 1] }
                ],
                createdRow: function(row, data) {
                    const enabled = data.enabled ?? data.Enabled;
                    if (enabled === false || enabled === 0) {
                        row.classList.add('sound-disabled-row');
                    }
                },
                buttons: [
                    {
                        text: '<i class="bi bi-plus-circle me-1"></i>Nuovo',
                        className: 'btn btn-sm btn-light border text-primary',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() { window.location.href = '/Sounds/Create'; }
                    },
                    {
                        text: '<i class="bi bi-stopwatch me-1"></i>Durate mancanti',
                        className: 'btn btn-sm btn-light border text-warning',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() {
                            var form = document.getElementById('enqueueMissingDurationsForm');
                            if (form) form.submit();
                        }
                    },
                    {
                        text: '<i class="bi bi-calculator me-1"></i>Score mancanti',
                        className: 'btn btn-sm btn-light border text-success',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() {
                            var form = document.getElementById('enqueueMissingScoresForm');
                            if (form) form.submit();
                        }
                    },
                    {
                        extend: 'colvis',
                        text: '<i class="bi bi-layout-three-columns me-1"></i>Colonne',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' }
                    },
                    {
                        text: '<i class="bi bi-arrow-clockwise me-1"></i>Refresh',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() { location.reload(); }
                    }
                ]
            });
        });
    }
})();
</script>
