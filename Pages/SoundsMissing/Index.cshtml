@page
@model TinyGenerator.Pages.SoundsMissing.IndexModel
@{
    ViewData["Title"] = "Sounds Missing";
    ViewData["PageDescription"] = "Richieste audio non trovate nella libreria sounds";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/buttons.bootstrap5.min.css" />
    <style>
        .btn-group-vertical > .btn, .btn-group > .btn { flex: none; }
        .cell-wrap { max-width: 420px; white-space: normal; word-break: break-word; }
        .cell-small { white-space: nowrap; }
        .prompt-cell { min-width: 260px; }
        .status-toggle { cursor: pointer; }
    </style>
}

<div class="container-fluid py-3">
    @if (!string.IsNullOrWhiteSpace(Model.ActionMessage))
    {
        <div class="alert alert-@(string.IsNullOrWhiteSpace(Model.ActionMessageType) ? "info" : Model.ActionMessageType)">
            @Model.ActionMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LoadError))
    {
        <div class="alert alert-warning">
            Errore caricando <code>sounds_missing</code>: @Model.LoadError
        </div>
    }

    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-auto">
            <label class="form-label mb-1" for="typeFilter">Tipo</label>
            <select class="form-select form-select-sm" id="typeFilter" name="typeFilter">
                @if (string.IsNullOrWhiteSpace(Model.TypeFilter))
                {
                    <option value="" selected>Tutti</option>
                }
                else
                {
                    <option value="">Tutti</option>
                }
                @if (Model.TypeFilter == "fx")
                {
                    <option value="fx" selected>fx</option>
                }
                else
                {
                    <option value="fx">fx</option>
                }
                @if (Model.TypeFilter == "amb")
                {
                    <option value="amb" selected>amb</option>
                }
                else
                {
                    <option value="amb">amb</option>
                }
                @if (Model.TypeFilter == "music")
                {
                    <option value="music" selected>music</option>
                }
                else
                {
                    <option value="music">music</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm btn-outline-primary">Applica filtro</button>
        </div>
        <div class="col-auto">
            <a class="btn btn-sm btn-outline-secondary" href="/SoundsMissing/Index">Reset</a>
        </div>
    </form>

    <form id="recheckMissingForm" method="post" asp-page-handler="RecheckAgainstSounds" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
        <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
    </form>
    <form id="enqueueSearchAllForm" method="post" asp-page-handler="EnqueueSearchAll" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
        <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
    </form>
    <form id="enqueueResetResolvedStoriesForm" method="post" asp-page-handler="EnqueueResetResolvedStories" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
        <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
    </form>
    <form id="deleteResolvedForm" method="post" asp-page-handler="DeleteResolved" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
        <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
    </form>
    <form id="deleteVisibleForm" method="post" asp-page-handler="DeleteVisible" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
        <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
        <input type="hidden" name="visibleIds" id="visibleIdsInput" value="" />
    </form>
    <form id="toggleStatusForm" method="post" asp-page-handler="ToggleStatus" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="card shadow-sm">
        <div class="card-body">
            <table id="soundsMissingTable" class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th data-col="id">Id</th>
                        <th data-col="status">Status</th>
                        <th data-col="type">Type</th>
                        <th data-col="occurrences">Occorrenze</th>
                        <th data-col="lastSeenAt">Last Seen</th>
                        <th data-col="firstSeenAt">First Seen</th>
                        <th data-col="prompt">Prompt</th>
                        <th data-col="tags">Tags</th>
                        <th data-col="storyId">Story Id</th>
                        <th data-col="storyTitle">Story Title</th>
                        <th data-col="source">Source</th>
                        <th data-col="notes">Notes</th>
                        <th data-col="actions">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td data-col="id" class="cell-small">@item.Id</td>
                            <td data-col="status">
                                <button type="button"
                                        class="btn btn-sm p-0 border-0 bg-transparent status-toggle js-toggle-status"
                                        data-id="@item.Id"
                                        data-status="@item.Status">
                                    <span class="badge @(item.Status == "resolved" ? "bg-success" : "bg-warning text-dark")">
                                        @item.Status
                                    </span>
                                </button>
                            </td>
                            <td data-col="type">
                                <span class="badge @(item.Type == "amb" ? "bg-success" : item.Type == "music" ? "bg-primary" : "bg-secondary")">@item.Type</span>
                            </td>
                            <td data-col="occurrences" class="cell-small">@item.Occurrences</td>
                            <td data-col="lastSeenAt" class="cell-small">@item.LastSeenAt</td>
                            <td data-col="firstSeenAt" class="cell-small">@item.FirstSeenAt</td>
                            <td data-col="prompt" class="cell-wrap prompt-cell">@item.Prompt</td>
                            <td data-col="tags" class="cell-wrap">@item.Tags</td>
                            <td data-col="storyId" class="cell-small">@item.StoryId</td>
                            <td data-col="storyTitle" class="cell-wrap">@item.StoryTitle</td>
                            <td data-col="source" class="cell-wrap">@item.Source</td>
                            <td data-col="notes" class="cell-wrap">@item.Notes</td>
                            <td data-col="actions" class="cell-small">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">Azioni</button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        @if (item.Status == "open" && (item.Type == "fx" || item.Type == "amb"))
                                        {
                                            <li>
                                                <form method="post" asp-page-handler="EnqueueSearchOne" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="typeFilter" value="@Model.TypeFilter" />
                                                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                                                    <button type="submit" class="dropdown-item">Cerca Online</button>
                                                </form>
                                            </li>
                                        }
                                        else
                                        {
                                            <li><span class="dropdown-item-text text-muted">Nessuna azione</span></li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
(function initSoundsMissingTable() {
    if (typeof jQuery === 'undefined') {
        setTimeout(initSoundsMissingTable, 50);
        return;
    }

    var scripts = [
        '/lib/datatables/js/jquery.dataTables.min.js',
        '/lib/datatables/js/dataTables.bootstrap5.min.js',
        '/lib/datatables/js/dataTables.buttons.min.js',
        '/lib/datatables/js/buttons.bootstrap5.min.js',
        '/lib/datatables/js/buttons.colVis.min.js'
    ];

    var idx = 0;
    function loadScript(url, callback) {
        var s = document.createElement('script');
        s.src = url;
        s.onload = callback;
        s.onerror = callback;
        document.head.appendChild(s);
    }
    function next() {
        if (idx < scripts.length) {
            loadScript(scripts[idx++], next);
            return;
        }
        initializeDataTable();
    }
    next();

    function initializeDataTable() {
        jQuery(function($) {
            if (typeof $.fn.DataTable === 'undefined') return;

            var table = $('#soundsMissingTable').DataTable({
                dom: "<'row mb-2'<'col-sm-6'B><'col-sm-6 text-end'f>>" +
                     "rt" +
                     "<'row mt-2'<'col-sm-6'i><'col-sm-6 text-end'p>>",
                stateSave: true,
                stateDuration: 0,
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                order: [[4, 'desc'], [0, 'desc']],
                buttons: [
                    {
                        text: '<i class="bi bi-cloud-download me-1"></i>Cerca Tutti (Open)',
                        className: 'btn btn-sm btn-light border text-primary',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() {
                            if (confirm('Accodare la ricerca online per tutti i sounds_missing aperti di tipo fx/amb?')) {
                                var form = document.getElementById('enqueueSearchAllForm');
                                if (form) form.submit();
                            }
                        }
                    },
                    {
                        text: '<i class="bi bi-arrow-repeat me-1"></i>Reset Storie (resolved)',
                        className: 'btn btn-sm btn-light border text-warning',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() {
                            if (confirm('Resettare a tts_generated le storie che hanno sounds_missing solo resolved (nessun open) e cancellare i resolved?')) {
                                var form = document.getElementById('enqueueResetResolvedStoriesForm');
                                if (form) form.submit();
                            }
                        }
                    },
                    {
                        text: '<i class="bi bi-trash me-1"></i>Cancella Resolved',
                        className: 'btn btn-sm btn-light border text-danger',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() {
                            if (confirm('Cancellare tutti i record sounds_missing con stato resolved?')) {
                                var form = document.getElementById('deleteResolvedForm');
                                if (form) form.submit();
                            }
                        }
                    },
                    {
                        text: '<i class="bi bi-trash3 me-1"></i>Cancella Visualizzati',
                        className: 'btn btn-sm btn-light border text-danger',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function(e, dt) {
                            var ids = [];
                            dt.rows({ search: 'applied' }).every(function() {
                                var rowNode = this.node();
                                var idCell = rowNode ? rowNode.querySelector('td[data-col=\"id\"]') : null;
                                var idText = idCell ? idCell.textContent.trim() : '';
                                var id = Number.parseInt(idText, 10);
                                if (Number.isFinite(id) && id > 0) {
                                    ids.push(id);
                                }
                            });

                            ids = Array.from(new Set(ids));
                            if (ids.length === 0) {
                                alert('Nessun record visualizzato da cancellare.');
                                return;
                            }

                            if (!confirm('Cancellare tutti i missing sound attualmente visualizzati in griglia?')) {
                                return;
                            }

                            var input = document.getElementById('visibleIdsInput');
                            var form = document.getElementById('deleteVisibleForm');
                            if (input && form) {
                                input.value = ids.join(',');
                                form.submit();
                            }
                        }
                    },
                    {
                        text: '<i class="bi bi-search me-1"></i>Verifica Mancanti',
                        className: 'btn btn-sm btn-light border text-primary',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() {
                            if (confirm('Verificare i tag mancanti contro la libreria sounds e rimuovere i record risolti?')) {
                                var form = document.getElementById('recheckMissingForm');
                                if (form) form.submit();
                            }
                        }
                    },
                    {
                        extend: 'colvis',
                        text: '<i class="bi bi-layout-three-columns me-1"></i>Colonne',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' }
                    },
                    {
                        text: '<i class="bi bi-arrow-clockwise me-1"></i>Refresh',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() { location.reload(); }
                    }
                ]
            });

            var toggleForm = document.getElementById('toggleStatusForm');
            var tokenInput = toggleForm ? toggleForm.querySelector('input[name="__RequestVerificationToken"]') : null;
            var antiForgeryToken = tokenInput ? tokenInput.value : '';

            $('#soundsMissingTable').on('click', '.js-toggle-status', function() {
                var $button = $(this);
                if ($button.data('busy') === true) {
                    return;
                }

                var id = Number($button.data('id'));
                var currentStatus = String($button.data('status') || '').toLowerCase();
                if (!id) {
                    return;
                }

                $button.data('busy', true);
                fetch('?handler=ToggleStatus', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'RequestVerificationToken': antiForgeryToken
                    },
                    body: 'id=' + encodeURIComponent(id) + '&currentStatus=' + encodeURIComponent(currentStatus)
                })
                .then(function(response) {
                    if (!response.ok) {
                        throw new Error('HTTP ' + response.status);
                    }
                    return response.json();
                })
                .then(function(data) {
                    if (!data || data.success !== true) {
                        throw new Error(data && data.message ? data.message : 'Errore aggiornando lo stato');
                    }

                    var nextStatus = String(data.status || 'open').toLowerCase();
                    $button.data('status', nextStatus);

                    var $badge = $button.find('.badge');
                    $badge.text(nextStatus);
                    $badge.removeClass('bg-success bg-warning text-dark');
                    if (nextStatus === 'resolved') {
                        $badge.addClass('bg-success');
                    } else {
                        $badge.addClass('bg-warning text-dark');
                    }
                })
                .catch(function(error) {
                    alert('Impossibile aggiornare lo stato: ' + (error && error.message ? error.message : 'errore sconosciuto'));
                })
                .finally(function() {
                    $button.data('busy', false);
                });
            });
        });
    }
})();
</script>
