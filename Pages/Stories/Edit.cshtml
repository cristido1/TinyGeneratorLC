@page "{id:long}"
@model TinyGenerator.Pages.Stories.EditModel
@{
    ViewData["Title"] = "Modifica storia";
}

<div class="card">
    <div class="card-body">
        <h3>Modifica storia</h3>
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        @if (TempData["StatusMessage"] != null)
        {
            <div class="alert alert-success">@TempData["StatusMessage"]</div>
        }
        <form method="post">
            <ul class="nav nav-tabs" id="storyEditTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="dati-tab" data-bs-toggle="tab" data-bs-target="#dati-pane" type="button" role="tab" aria-controls="dati-pane" aria-selected="true">Dati</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="storia-tab" data-bs-toggle="tab" data-bs-target="#storia-pane" type="button" role="tab" aria-controls="storia-pane" aria-selected="false">Storia</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="revised-tab" data-bs-toggle="tab" data-bs-target="#revised-pane" type="button" role="tab" aria-controls="revised-pane" aria-selected="false">Story revised</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tagged-tab" data-bs-toggle="tab" data-bs-target="#tagged-pane" type="button" role="tab" aria-controls="tagged-pane" aria-selected="false">Story Tagged</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="personaggi-tab" data-bs-toggle="tab" data-bs-target="#personaggi-pane" type="button" role="tab" aria-controls="personaggi-pane" aria-selected="false">Personaggi</button>
                </li>
            </ul>

            <div class="tab-content mt-3 story-edit-tab-content" id="storyEditTabsContent">
                <div class="tab-pane fade show active" id="dati-pane" role="tabpanel" aria-labelledby="dati-tab">
                    <div class="mb-3">
                        <label class="form-label">Id</label>
                        <input class="form-control" asp-for="Id" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Titolo</label>
                        <input class="form-control" asp-for="Title" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Agente (opzionale)</label>
                        <select class="form-select" asp-for="AgentId">
                            <option value="">-- nessuno --</option>
                            @foreach(var ag in Model.Agents)
                            {
                                <option value="@ag.Id" selected="@((Model.AgentId==ag.Id)?"selected":"")">@ag.Name (@ag.Role)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Modello (opzionale)</label>
                        <select class="form-select" asp-for="ModelId">
                            <option value="">-- nessuno --</option>
                            @foreach(var m in Model.Models)
                            {
                                <option value="@m.Id" selected="@((Model.ModelId==m.Id)?"selected":"")">@m.Name (@m.Provider) @(m.Speed.HasValue ? "(sp:" + m.Speed.ToString() + ")" : "(sp:-)")</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Prompt</label>
                        <input class="form-control" asp-for="Prompt" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" asp-for="StatusId">
                            <option value="">-- nessuno --</option>
                            @foreach (var status in Model.Statuses)
                            {
                                <option value="@status.Id">@((status.Description ?? status.Code) ?? "N/D") (@status.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Serie</label>
                        <select class="form-select" asp-for="SerieId">
                            <option value="">-- nessuna --</option>
                            @foreach(var serie in Model.Series)
                            {
                                <option value="@serie.Id" selected="@((Model.SerieId==serie.Id)?"selected":"")">@serie.Titolo</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Episodio</label>
                        <input type="number" class="form-control" asp-for="SerieEpisode" placeholder="Numero episodio (1, 2, 3...)" min="1" />
                        <small class="text-muted">Inserire solo se la storia fa parte di una serie</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Personaggi (JSON)</label>
                        <textarea class="form-control" rows="6" asp-for="Characters" placeholder='[{"name": "Nome", "gender": "male", "age": "35"}]'></textarea>
                        <small class="text-muted">Array JSON con name, gender, age, title, role, aliases</small>
                    </div>
                </div>
                <div class="tab-pane fade story-tab-pane" id="storia-pane" role="tabpanel" aria-labelledby="storia-tab">
                    <div class="d-flex flex-column h-100">
                        <label class="form-label">Story raw</label>
                        <textarea class="form-control flex-grow-1 story-textarea" asp-for="StoryText"></textarea>
                    </div>
                </div>
                <div class="tab-pane fade story-tab-pane" id="revised-pane" role="tabpanel" aria-labelledby="revised-tab">
                    <div class="d-flex flex-column h-100">
                        <label class="form-label">Story revised</label>
                        <textarea class="form-control flex-grow-1 story-textarea" asp-for="StoryRevisedText"></textarea>
                    </div>
                </div>
                <div class="tab-pane fade story-tab-pane" id="tagged-pane" role="tabpanel" aria-labelledby="tagged-tab">
                    <div class="mb-3">
                        <label class="form-label">Agente formatter</label>
                        <input class="form-control" value="@Model.FormatterAgentName" disabled />
                    </div>
                    <div class="d-flex flex-column h-100">
                        <label class="form-label">Story tagged</label>
                        <textarea class="form-control flex-grow-1 story-textarea" asp-for="StoryTaggedText"></textarea>
                    </div>
                </div>
                <div class="tab-pane fade" id="personaggi-pane" role="tabpanel" aria-labelledby="personaggi-tab">
                    <div class="d-flex gap-2 mb-3">
                        <button type="submit" asp-page-handler="ReassignVoices" class="btn btn-outline-primary">
                            Riassegna tutte
                        </button>
                    </div>
                    @if (Model.CharacterVoices == null || Model.CharacterVoices.Count == 0)
                    {
                        <div class="alert alert-warning mb-0">
                            Nessun personaggio trovato nel file <code>tts_schema.json</code>.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Personaggio</th>
                                        <th>Gender</th>
                                        <th>Voce</th>
                                        <th style="width:140px;">Preview</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.CharacterVoices.Count; i++)
                                    {
                                        var row = Model.CharacterVoices[i];
                                        var selectId = $"voiceSelect_{i}";
                                        <tr>
                                            <td>
                                                <input type="hidden" name="PostedCharacterVoices[@i].Index" value="@row.Index" />
                                                <input type="hidden" name="PostedCharacterVoices[@i].Name" value="@row.Name" />
                                                <input type="hidden" name="PostedCharacterVoices[@i].Voice" value="@row.Voice" />
                                                <strong>@row.Name</strong>
                                            </td>
                                            <td>
                                                <select name="PostedCharacterVoices[@i].Gender" class="form-select form-select-sm">
                                                    <option value="" selected="@(string.IsNullOrWhiteSpace(row.Gender) ? "selected" : null)">--</option>
                                                    <option value="male" selected="@(string.Equals(row.Gender, "male", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">male</option>
                                                    <option value="female" selected="@(string.Equals(row.Gender, "female", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">female</option>
                                                    <option value="robot" selected="@(string.Equals(row.Gender, "robot", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">robot</option>
                                                    <option value="alien" selected="@(string.Equals(row.Gender, "alien", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">alien</option>
                                                </select>
                                            </td>
                                            <td>
                                                <select id="@selectId" name="PostedCharacterVoices[@i].VoiceId" class="form-select form-select-sm voice-select">
                                                    <option value="">-- nessuna voce --</option>
                                                    @foreach (var voice in Model.AvailableVoices)
                                                    {
                                                        var templateUrl = voice.TemplateUrl ?? string.Empty;
                                                        var sampleUrl = voice.SampleUrl ?? string.Empty;
                                                        var label = $"{voice.Name} ({voice.VoiceId})";
                                                        if (!string.IsNullOrWhiteSpace(voice.Gender))
                                                        {
                                                            label += $" [{voice.Gender}]";
                                                        }
                                                        if (!string.IsNullOrWhiteSpace(voice.Age))
                                                        {
                                                            label += $" [eta: {voice.Age}]";
                                                        }
                                                        if (!string.IsNullOrWhiteSpace(voice.Archetype))
                                                        {
                                                            label += $" - {voice.Archetype}";
                                                        }
                                                        <option value="@voice.VoiceId"
                                                                data-template-url="@templateUrl"
                                                                data-sample-url="@sampleUrl"
                                                                selected="@(string.Equals(row.VoiceId, voice.VoiceId, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                                            @label
                                                        </option>
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-sm btn-outline-secondary play-voice-preview-btn" data-select-id="@selectId">
                                                    Ascolta
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <audio id="voicePreviewAudio" class="w-100 d-none mt-2" controls preload="none"></audio>
                    }
                </div>
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Salva</button>
                <a class="btn btn-secondary" asp-page="/Stories/Index">Annulla</a>
            </div>
        </form>
    </div>
</div>

<style>
    .story-edit-tab-content {
        min-height: 60vh;
    }
    .story-tab-pane {
        height: 60vh;
    }
    .story-textarea {
        min-height: 55vh;
        height: 100%;
        resize: vertical;
    }
</style>

<script>
    (function(){
        const queryTab = '@(Model.Tab ?? string.Empty)';
        const storageKey = 'stories-edit-active-tab';
        const tabToActivate = queryTab || localStorage.getItem(storageKey);
        if (tabToActivate) {
            const targetButton = document.querySelector('#storyEditTabs button[data-bs-target="#' + tabToActivate + '-pane"]');
            if (targetButton) {
                const tab = bootstrap.Tab.getOrCreateInstance(targetButton);
                tab.show();
            }
        }

        document.querySelectorAll('#storyEditTabs button[data-bs-toggle="tab"]').forEach(btn => {
            btn.addEventListener('shown.bs.tab', function(ev) {
                const target = ev.target.getAttribute('data-bs-target') || '';
                const id = target.replace('#', '').replace('-pane', '');
                if (id) localStorage.setItem(storageKey, id);
            });
        });
    })();
</script>
<script>
    (function(){
        const audio = document.getElementById('voicePreviewAudio');
        if (!audio) return;

        function getSelectedAudioUrl(selectEl) {
            if (!selectEl) return '';
            const opt = selectEl.options[selectEl.selectedIndex];
            if (!opt) return '';
            const templateUrl = opt.getAttribute('data-template-url') || '';
            const sampleUrl = opt.getAttribute('data-sample-url') || '';
            return templateUrl || sampleUrl;
        }

        document.addEventListener('click', async function(e){
            const btn = e.target.closest && e.target.closest('.play-voice-preview-btn');
            if (!btn) return;
            const selectId = btn.getAttribute('data-select-id');
            if (!selectId) return;
            const selectEl = document.getElementById(selectId);
            const url = getSelectedAudioUrl(selectEl);
            if (!url) {
                alert('Nessun template/sample disponibile per la voce selezionata.');
                return;
            }
            try {
                btn.disabled = true;
                audio.classList.remove('d-none');
                audio.pause();
                audio.src = url;
                audio.load();
                await audio.play();
            } catch (err) {
                alert('Errore durante la riproduzione audio.');
            } finally {
                btn.disabled = false;
            }
        });
    })();
</script>
