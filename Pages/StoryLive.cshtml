@page "{id:long?}"
@model TinyGenerator.Pages.StoryLiveModel
@{
    ViewData["Title"] = "Story Live";
}

<style>
    .live-wrap { max-width: 1100px; margin: 0 auto; padding: 16px; }
    .live-head { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 10px; margin-bottom: 12px; }
    .live-card { border: 1px solid #d9d9d9; border-radius: 8px; background: #fff; padding: 10px 12px; }
    .live-label { font-size: 12px; text-transform: uppercase; color: #6c757d; }
    .live-value { font-size: 15px; font-weight: 600; color: #222; word-break: break-word; }
    .live-status { margin-bottom: 12px; font-size: 13px; color: #495057; }
    .live-section-title { font-size: 13px; text-transform: uppercase; color: #6c757d; margin: 8px 0; }
    .live-plan {
        min-height: 140px;
        max-height: 320px;
        white-space: pre-wrap;
        border: 1px solid #d9d9d9;
        border-radius: 8px;
        background: #f8f9fa;
        padding: 12px;
        font-size: 14px;
        line-height: 1.4;
        overflow: auto;
        margin-bottom: 12px;
    }
    .live-output {
        min-height: 55vh;
        white-space: pre-wrap;
        border: 1px solid #d9d9d9;
        border-radius: 8px;
        background: #fbfbfb;
        padding: 14px;
        font-size: 15px;
        line-height: 1.45;
        overflow: auto;
    }
</style>

<div class="live-wrap">
    <div class="live-head">
        <div class="live-card">
            <div class="live-label">Titolo Storia</div>
            <div class="live-value" id="storyTitle">@Model.StoryTitle</div>
        </div>
        <div class="live-card">
            <div class="live-label">Agente</div>
            <div class="live-value" id="agentName">In attesa...</div>
        </div>
        <div class="live-card">
            <div class="live-label">Modello</div>
            <div class="live-value" id="modelName">In attesa...</div>
        </div>
    </div>

    <div class="live-status" id="liveStatus">Connessione in corso...</div>
    <div class="live-section-title">Piano NRE (nre_planner)</div>
    <div class="live-plan" id="planOutput">@Model.NrePlanSummary</div>
    <div class="live-section-title">Testo approvato consolidato</div>
    <div class="live-output" id="liveOutput">@Model.ApprovedText</div>
</div>

@section Scripts {
<script>
(() => {
    let currentStoryId = @Model.StoryId;
    const initialGroup = currentStoryId > 0 ? `story_live_${currentStoryId}` : null;
    let refreshTimer = null;
    const out = document.getElementById('liveOutput');
    const planOut = document.getElementById('planOutput');
    const statusEl = document.getElementById('liveStatus');
    const titleEl = document.getElementById('storyTitle');
    const agentEl = document.getElementById('agentName');
    const modelEl = document.getElementById('modelName');

    function setStatus(text) {
        if (statusEl) statusEl.textContent = text;
    }

    function setConsolidated(plan, text) {
        if (planOut) planOut.textContent = plan || '';
        if (out) out.textContent = text || '';
        if (out) out.scrollTop = out.scrollHeight;
    }

    function matchesStory(payload) {
        const incoming = payload && payload.storyId ? Number(payload.storyId) : 0;
        if (currentStoryId <= 0 && incoming > 0) {
            currentStoryId = incoming;
            return true;
        }
        return incoming > 0 && incoming === Number(currentStoryId);
    }

    async function refreshState() {
        if (!currentStoryId || Number(currentStoryId) <= 0) return;
        try {
            const res = await fetch(`@Url.Page("/StoryLive")?handler=State&id=${encodeURIComponent(currentStoryId)}`);
            if (!res.ok) return;
            const data = await res.json();
            if (!data || !data.ok) return;
            if (titleEl && data.title) titleEl.textContent = data.title;
            setConsolidated(data.nrePlanSummary || '', data.approvedText || '');
        } catch (e) {
            console.error(e);
        }
    }

    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/storyLiveHub')
        .withAutomaticReconnect()
        .build();

    connection.on('StoryLiveStarted', payload => {
        if (!payload || !matchesStory(payload)) return;
        if (titleEl && payload.title) titleEl.textContent = payload.title;
        if (agentEl) agentEl.textContent = payload.agentName || 'N/A';
        if (modelEl) modelEl.textContent = payload.modelName || 'N/A';
        if (typeof payload.nrePlanSummary !== 'undefined' || typeof payload.approvedText !== 'undefined') {
            setConsolidated(payload.nrePlanSummary || '', payload.approvedText || '');
        }
        setStatus('Streaming in corso...');
        refreshState();
    });

    connection.on('StoryLiveChunk', payload => {
        if (!payload || !matchesStory(payload)) return;
        // Legacy event from CallCenter streaming: keep as fallback by reloading state.
        refreshState();
    });

    connection.on('StoryLiveConsolidated', payload => {
        if (!payload || !matchesStory(payload)) return;
        setConsolidated(payload.nrePlanSummary || '', payload.approvedText || '');
        const step = Number(payload.currentStep || 0);
        const max = Number(payload.maxStep || 0);
        const phase = payload.phase ? ` - ${payload.phase}` : '';
        if (step > 0 && max > 0) {
            setStatus(`Consolidato step ${step}/${max}${phase}`);
        } else {
            setStatus(`Consolidato${phase}`);
        }
    });

    connection.on('StoryLiveCompleted', payload => {
        if (!payload || !matchesStory(payload)) return;
        if (typeof payload.nrePlanSummary !== 'undefined' || typeof payload.approvedText !== 'undefined') {
            setConsolidated(payload.nrePlanSummary || '', payload.approvedText || '');
        }
        setStatus('Completato. In attesa di eventuali nuovi tentativi...');
        refreshState();
    });

    connection.on('StoryLiveFailed', payload => {
        if (!payload || !matchesStory(payload)) return;
        if (typeof payload.nrePlanSummary !== 'undefined' || typeof payload.approvedText !== 'undefined') {
            setConsolidated(payload.nrePlanSummary || '', payload.approvedText || '');
        }
        const err = payload && payload.error ? payload.error : 'Errore durante la generazione';
        setStatus(`Fallito: ${err}`);
        refreshState();
    });

    connection.onreconnected(async () => {
        try {
            if (currentStoryId > 0) {
                await connection.invoke('JoinGroup', `story_live_${currentStoryId}`);
            }
        } catch (e) {
            console.error(e);
        }
        refreshState();
    });

    async function start() {
        try {
            await connection.start();
            if (initialGroup) {
                await connection.invoke('JoinGroup', initialGroup);
            }
            setStatus(initialGroup ? 'Connesso. In attesa di output...' : 'Connesso. In attesa di una storia in streaming...');
            await refreshState();
            refreshTimer = setInterval(refreshState, 2000);
        } catch (e) {
            console.error(e);
            setStatus('Errore connessione live.');
        }
    }

    start();
})();
</script>
}
