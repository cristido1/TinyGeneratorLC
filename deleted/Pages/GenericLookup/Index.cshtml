@page
@model TinyGenerator.Pages.GenericLookup.IndexModel
@{
    ViewData["Title"] = "Generic Lookup";
    ViewData["PageDescription"] = "Gestione valori lookup tipizzati";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/buttons.bootstrap5.min.css" />
    <style>
        .btn-group-vertical > .btn, .btn-group > .btn { flex: none; }
        #genericLookupTable thead th {
            font-weight: 600;
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: .4px;
        }
        .table-wrap {
            border: 1px solid #dee2e6;
            border-radius: .375rem;
            padding: 1rem;
            background: #fff;
        }
    </style>
}

<div class="container-fluid py-3">
    @if (TempData["Message"] is string okMsg && !string.IsNullOrWhiteSpace(okMsg))
    {
        <div class="alert alert-success py-2">@okMsg</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LoadError))
    {
        <div class="alert alert-danger py-2">@Model.LoadError</div>
    }

    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-sm-4 col-md-3">
            <label class="form-label mb-1" for="searchTop">Cerca</label>
            <input id="searchTop" type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="Type, code, value..." />
        </div>
        <div class="col-sm-4 col-md-3">
            <label class="form-label mb-1" for="typeFilter">Filtro Type</label>
            <select id="typeFilter" name="type" class="form-select form-select-sm">
                @if (string.IsNullOrWhiteSpace(Model.TypeFilter))
                {
                    <option value="" selected>Tutti i type</option>
                }
                else
                {
                    <option value="">Tutti i type</option>
                }
                @foreach (var t in Model.Types)
                {
                    if (string.Equals(t, Model.TypeFilter, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@t" selected>@t</option>
                    }
                    else
                    {
                        <option value="@t">@t</option>
                    }
                }
            </select>
        </div>
        <div class="col-sm-auto">
            <button type="submit" class="btn btn-sm btn-primary">Filtra</button>
        </div>
        <div class="col-sm-auto">
            <a href="/GenericLookup/Index" class="btn btn-sm btn-outline-secondary">Reset</a>
        </div>
    </form>

    <div class="table-wrap">
        <table id="genericLookupTable" class="table table-hover align-middle">
            <thead>
                <tr>
                    <th data-col="actions">Azioni</th>
                    <th data-col="id">Id</th>
                    <th data-col="type">Type</th>
                    <th data-col="code">Code</th>
                    <th data-col="value">Value</th>
                    <th data-col="description">Description</th>
                    <th data-col="sortOrder">Sort</th>
                    <th data-col="isActive">Active</th>
                    <th data-col="weight">Weight</th>
                    <th data-col="createdAt">CreatedAt</th>
                    <th data-col="updatedAt">UpdatedAt</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td data-col="actions">
                            <div class="d-flex gap-1">
                                <a class="btn btn-sm btn-light border" asp-page="./Edit" asp-route-id="@item.Id">Edit</a>
                                <a class="btn btn-sm btn-light border text-danger" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                            </div>
                        </td>
                        <td data-col="id">@item.Id</td>
                        <td data-col="type"><strong>@item.Type</strong></td>
                        <td data-col="code">@item.Code</td>
                        <td data-col="value">@item.Value</td>
                        <td data-col="description">@item.Description</td>
                        <td data-col="sortOrder">@item.SortOrder</td>
                        <td data-col="isActive">@((item.IsActive) ? "Yes" : "No")</td>
                        <td data-col="weight">@item.Weight</td>
                        <td data-col="createdAt">@item.CreatedAt</td>
                        <td data-col="updatedAt">@item.UpdatedAt</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
(function initGenericLookupTable() {
    if (typeof jQuery === 'undefined') {
        setTimeout(initGenericLookupTable, 50);
        return;
    }

    var scripts = [
        '/lib/datatables/js/jquery.dataTables.min.js',
        '/lib/datatables/js/dataTables.bootstrap5.min.js',
        '/lib/datatables/js/dataTables.buttons.min.js',
        '/lib/datatables/js/buttons.bootstrap5.min.js',
        '/lib/datatables/js/buttons.colVis.min.js'
    ];

    var idx = 0;
    function loadScript(url, callback) {
        var s = document.createElement('script');
        s.src = url;
        s.onload = callback;
        s.onerror = callback;
        document.head.appendChild(s);
    }

    function next() {
        if (idx < scripts.length) {
            loadScript(scripts[idx++], next);
            return;
        }
        initTable();
    }

    next();

    function initTable() {
        jQuery(function($) {
            $('#genericLookupTable').DataTable({
                dom: "<'row mb-2'<'col-sm-6'B><'col-sm-6 text-end'f>>" +
                     "rt" +
                     "<'row mt-2'<'col-sm-6'i><'col-sm-6 text-end'p>>",
                stateSave: true,
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                order: [[2, 'asc'], [6, 'asc'], [1, 'asc']],
                columnDefs: [
                    { orderable: false, targets: 0 }
                ],
                buttons: [
                    {
                        text: '<i class="bi bi-plus-circle me-1"></i>Nuovo',
                        className: 'btn btn-sm btn-light border text-primary',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() { window.location.href = '/GenericLookup/Edit'; }
                    },
                    {
                        extend: 'colvis',
                        text: '<i class="bi bi-layout-three-columns me-1"></i>Colonne',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' }
                    },
                    {
                        text: '<i class="bi bi-arrow-clockwise me-1"></i>Refresh',
                        className: 'btn btn-sm btn-light border',
                        attr: { style: 'width: auto; flex: 0 0 auto;' },
                        action: function() { location.reload(); }
                    }
                ]
            });
        });
    }
})();
</script>
